local _snapshotCache={}; local _snapshotCacheTime=0; local _snapshotCacheTTL=5

local function getFishBagSnapshot(forceRefresh)
    local now=tick()
    if not forceRefresh and now-_snapshotCacheTime<_snapshotCacheTTL then return _snapshotCache end
    local items={}
    pcall(function()
        local FishUISrv=ReplicatedStorage:WaitForChild("FishUI",5):WaitForChild("ToServer",5)
        local ok,result=pcall(function() return FishUISrv:WaitForChild("RequestSnapshot",5):InvokeServer() end)
        if not ok or type(result)~="table" then return end
        if type(result.items)=="table" then
            for _,fish in pairs(result.items) do if type(fish)=="table" and fish.Species then table.insert(items,fish) end end
        elseif type(result.Items)=="table" then
            for _,fish in pairs(result.Items) do if type(fish)=="table" and fish.Species then table.insert(items,fish) end end
        else
            for _,page in pairs(result) do
                if type(page)=="table" then
                    if page.Species then table.insert(items,page)
                    else for _,fish in pairs(page) do if type(fish)=="table" and fish.Species then table.insert(items,fish) end end end
                end
            end
        end
    end)
    _snapshotCache=items; _snapshotCacheTime=now
    return items
end

local function findFishZone(fishSpecies)
    local nameUp=fishSpecies:upper():gsub("%s+","_"):gsub("[^%w_]","")
    for _,fish in pairs(getFishBagSnapshot()) do
        local sp=tostring(fish.Species or ""):upper():gsub("%s+","_"):gsub("[^%w_]","")
        if sp==nameUp then
            local zone=tostring(fish.CaughtZone or ""):upper():gsub("%s+","_")
            if zone~="" and zone~="?" then return zone end
        end
    end
    return "OPEN_OCEAN"
end

