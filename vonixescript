local function setCharFreeze(state)
    if freezeConnection then freezeConnection:Disconnect(); freezeConnection=nil end
    if freezeCharConn then freezeCharConn:Disconnect(); freezeCharConn=nil end
    pcall(function()
        local oldPlat = workspace:FindFirstChild("vonixePlatform")
        if oldPlat then oldPlat:Destroy() end
        local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _,v in pairs(hrp:GetChildren()) do
                if v.Name=="vonixeAP" or v.Name=="vonixeAO" or v.Name=="vonixeAtt" then v:Destroy() end
            end
        end
    end)

    frozenCFrame=nil
    if state then
        pcall(function()
            local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then 
                frozenCFrame=hrp.CFrame
                hrp.Anchored=false 

                local att = Instance.new("Attachment")
                att.Name = "vonixeAtt"
                att.Parent = hrp
                
                local ap = Instance.new("AlignPosition")
                ap.Name = "vonixeAP"
                ap.Mode = Enum.PositionAlignmentMode.OneAttachment
                ap.Attachment0 = att
                ap.RigidityEnabled = true
                ap.Position = frozenCFrame.Position
                ap.Parent = hrp
                
                local ao = Instance.new("AlignOrientation")
                ao.Name = "vonixeAO"
                ao.Mode = Enum.OrientationAlignmentMode.OneAttachment
                ao.Attachment0 = att
                ao.RigidityEnabled = true
                ao.CFrame = frozenCFrame
                ao.Parent = hrp
            end
        end)
        
        -- Buat platform solid di bawah kaki supaya physics game nganggap kita lagi berdiri normal
        if frozenCFrame then
            pcall(function()
                local plat = Instance.new("Part")
                plat.Name = "vonixePlatform"
                plat.Size = Vector3.new(2.5, 1, 2.5)
                plat.Anchored = true
                plat.Transparency = 1
                plat.CanCollide = true
                plat.CFrame = frozenCFrame * CFrame.new(0, -3.5, 0)
                plat.Parent = workspace
            end)
        end

        local _lft=0
        freezeConnection=RunService.Heartbeat:Connect(function()
            local now=tick(); if now-_lft<0.05 then return end; _lft=now
            pcall(function()
                local char=Player.Character; if not char then return end
                local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
                if not frozenCFrame then frozenCFrame=hrp.CFrame end
                hrp.Velocity=Vector3.new(0,0,0); hrp.RotVelocity=Vector3.new(0,0,0)
                hrp.Anchored=false
            end)
        end)
        freezeCharConn=Player.CharacterAdded:Connect(function()
            if freezeConnection then freezeConnection:Disconnect(); freezeConnection=nil end
            if freezeCharConn then freezeCharConn:Disconnect(); freezeCharConn=nil end
            frozenCFrame=nil
            pcall(function()
                local oldPlat = workspace:FindFirstChild("vonixePlatform")
                if oldPlat then oldPlat:Destroy() end
            end)
        end)
    else
        pcall(function()
            local char=Player.Character
            if char then local hrp=char:FindFirstChild("HumanoidRootPart"); if hrp then hrp.Anchored=false; hrp.Velocity=Vector3.new(0,0,0) end end
        end)
    end
end

local function getZoneData(zoneName)
    if not zoneName then return nil end
    local upper=zoneName:upper():gsub("%s+","_"):gsub("[^%w_]","")
    if zoneMap[upper] then return zoneMap[upper] end
    local bk,bl=nil,0
    for key in pairs(zoneMap) do if upper:find(key,1,true) and #key>bl then bl=#key; bk=key end end
    if bk then return zoneMap[bk] end; return nil
end

