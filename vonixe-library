    function Window:AddMonitor(mConfig)
        local tab = self:AddTab({ Title = mConfig.Title or "Monitor", Icon = mConfig.Icon or "activity" })

        -- Status banner besar
        local statusBanner = frame({
            Size             = UDim2.new(1, 0, 0, 52),
            BackgroundColor3 = Theme.BG3,
        }, tab._content)
        corner(10, statusBanner)
        stroke(Theme.STROKE2, 1, statusBanner)

        -- Animated left bar
        local statusBar = frame({
            Size             = UDim2.new(0, 3, 0, 32),
            Position         = UDim2.new(0, 10, 0.5, -16),
            BackgroundColor3 = Theme.GREEN,
        }, statusBanner)
        corner(99, statusBar)

        -- Pulse animasi
        local pulseConn
        local function startPulse(col)
            if pulseConn then pcall(function() pulseConn:Disconnect() end) end
            statusBar.BackgroundColor3 = col
            local bright = col:Lerp(Color3.new(1,1,1), 0.3)
            local t = 0
            pulseConn = RunService.Heartbeat:Connect(function(dt)
                t = t + dt * 2
                local a = (math.sin(t) + 1) / 2
                statusBar.BackgroundColor3 = col:Lerp(bright, a * 0.4)
            end)
        end
        startPulse(Theme.TEXT3)

        local statusDot = frame({
            Size             = UDim2.new(0, 8, 0, 8),
            Position         = UDim2.new(0, 20, 0.5, -4),
            BackgroundColor3 = Theme.TEXT3,
        }, statusBanner)
        corner(99, statusDot)

        local statusLbl = label("IDLE", 14, Enum.Font.GothamBold, Theme.TEXT2, Enum.TextXAlignment.Left, statusBanner)
        statusLbl.Size     = UDim2.new(0.6, 0, 1, 0)
        statusLbl.Position = UDim2.new(0, 36, 0, 0)

        local statusTime = label("--:--", 13, Enum.Font.GothamBold, Theme.TEXT3, Enum.TextXAlignment.Right, statusBanner)
        statusTime.Size     = UDim2.new(0.4, -14, 1, 0)
        statusTime.Position = UDim2.new(0.6, 0, 0, 0)

        -- Cards grid
        local cards = {}
        local function addCard(parent, title, value, accent)
            local card = frame({
                Size             = UDim2.new(0.5, -3, 0, 58),
                BackgroundColor3 = Theme.BG2,
            }, parent)
            corner(10, card)
            stroke(Theme.STROKE, 1, card)

            -- accent top bar gradient
            local acc = frame({
                Size             = UDim2.new(0, 22, 0, 2),
                Position         = UDim2.new(0, 10, 0, 0),
                BackgroundColor3 = accent or Theme.ACCENT3,
            }, card)
            corner(99, acc)
            gradient(Theme.ACCENT1, accent or Theme.ACCENT2, 0, acc)

            local tl = label(title, 10, Enum.Font.Gotham, Theme.TEXT3, Enum.TextXAlignment.Left, card)
            tl.Size     = UDim2.new(1, -12, 0, 16)
            tl.Position = UDim2.new(0, 10, 0, 10)

            local vl = label(value, 20, Enum.Font.GothamBlack, Theme.TEXT, Enum.TextXAlignment.Left, card)
            vl.Size     = UDim2.new(1, -12, 0, 26)
            vl.Position = UDim2.new(0, 10, 0, 28)

            return card, vl
        end

        -- Grid wrapper (2 kolom)
        local function makeGrid(cardDefs)
            local grid = frame({
                Size             = UDim2.new(1, 0, 0, 0),
                AutomaticSize    = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
            }, tab._content)

            local layout = Instance.new("UIGridLayout")
            layout.CellSize         = UDim2.new(0.5, -3, 0, 58)
            layout.CellPadding      = UDim2.new(0, 6, 0, 6)
            layout.FillDirection    = Enum.FillDirection.Horizontal
            layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
            layout.SortOrder        = Enum.SortOrder.LayoutOrder
            layout.Parent           = grid

            -- Auto resize grid
            layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                grid.Size = UDim2.new(1, 0, 0, layout.AbsoluteContentSize.Y)
            end)

            local valueLabels = {}
            for _, def in ipairs(cardDefs) do
                local _, vl = addCard(grid, def[1], def[2], def[3])
                table.insert(valueLabels, vl)
            end
            return valueLabels
        end

        -- Bar chart mini
        local function makeBar(parent, title, col)
            local wrapper = frame({
                Size             = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = Theme.BG2,
            }, parent)
            corner(8, wrapper)
            stroke(Theme.STROKE, 1, wrapper)

            local tl = label(title, 10, Enum.Font.Gotham, Theme.TEXT3, Enum.TextXAlignment.Left, wrapper)
            tl.Size     = UDim2.new(0.5, 0, 1, 0)
            tl.Position = UDim2.new(0, 10, 0, 0)

            local track = frame({
                Size             = UDim2.new(0.45, 0, 0, 6),
                Position         = UDim2.new(0.5, 0, 0.5, -3),
                BackgroundColor3 = Color3.fromRGB(30, 22, 14),
            }, wrapper)
            corner(99, track)

            local fill = frame({
                Size             = UDim2.new(0, 0, 1, 0),
                BackgroundColor3 = col or Theme.ACCENT1,
            }, track)
            corner(99, fill)
            gradient(col or Theme.ACCENT1, (col or Theme.ACCENT1):Lerp(Color3.new(1,1,1), 0.2), 0, fill)

            local valLbl = label("0", 10, Enum.Font.GothamBold, col or Theme.ACCENT2, Enum.TextXAlignment.Right, wrapper)
            valLbl.Size     = UDim2.new(0, 36, 1, 0)
            valLbl.Position = UDim2.new(1, -40, 0, 0)

            return {
                SetValue = function(_, ratio, text)
                    tween(fill, 0.3, {Size = UDim2.new(math.clamp(ratio, 0, 1), 0, 1, 0)})
                    valLbl.Text = text or tostring(math.floor(ratio * 100)) .. "%"
                end
            }
        end

        -- Monitor object yang dikembalikan ke user
        local Monitor = {}
        Monitor._cards    = {}
        Monitor._bars     = {}
        Monitor._conn     = nil

        -- Section stats cards
        tab:AddSection({ Title = "Statistics" })
        local statDefs = mConfig.Stats or {
            { "Total Cast",   "0" },
            { "Total Ikan",   "0" },
            { "Cast/Menit",   "0/m" },
            { "Ikan/Menit",   "0/m" },
            { "Total Sell",   "0x" },
            { "Respawn",      "0x" },
        }
        Monitor._statLabels = makeGrid(statDefs)

        -- Section bars (opsional)
        if mConfig.Bars then
            tab:AddSection({ Title = "Rates" })
            for _, b in ipairs(mConfig.Bars) do
                local bar = makeBar(tab._content, b.Title, b.Color)
                table.insert(Monitor._bars, { obj = bar, key = b.Key })
            end
        end

        -- Update function yang dipanggil user
        function Monitor:Update(data)
            -- Status
            if data.status then
                local colors = {
                    FISHING    = Theme.GREEN,
                    IDLE       = Theme.TEXT3,
                    RESPAWNING = Theme.YELLOW,
                    ["EQUIP ROD"] = Color3.fromRGB(100, 180, 255),
                    MISSION    = Theme.ACCENT2,
                }
                local col = colors[data.status] or Theme.TEXT3
                statusLbl.Text      = data.status
                statusLbl.TextColor3 = col
                statusDot.BackgroundColor3 = col
                startPulse(col)
            end
            if data.time then
                statusTime.Text = data.time
            end

            -- Stat cards
            if data.stats then
                for i, val in ipairs(data.stats) do
                    if Monitor._statLabels[i] then
                        Monitor._statLabels[i].Text = tostring(val)
                        -- Animate angka berubah
                        tween(Monitor._statLabels[i], 0.1, {TextColor3 = Theme.ACCENT2})
                        task.delay(0.15, function()
                            tween(Monitor._statLabels[i], 0.2, {TextColor3 = Theme.TEXT})
                        end)
                    end
                end
            end

            -- Bars
            if data.bars then
                for i, barData in ipairs(data.bars) do
                    if Monitor._bars[i] then
                        Monitor._bars[i].obj:SetValue(barData.ratio, barData.text)
                    end
                end
            end
        end

        -- Auto update via callback tiap interval
        function Monitor:StartAutoUpdate(interval, callback)
            if Monitor._conn then Monitor._conn:Disconnect() end
            local t = 0
            Monitor._conn = RunService.Heartbeat:Connect(function(dt)
                t = t + dt
                if t >= (interval or 0.5) then
                    t = 0
                    local data = callback()
                    if data then Monitor:Update(data) end
                end
            end)
        end

        function Monitor:Stop()
            if Monitor._conn then Monitor._conn:Disconnect(); Monitor._conn = nil end
            if pulseConn then pulseConn:Disconnect(); pulseConn = nil end
        end

        return Monitor
    end

    -- Window-level aliases (WindUI compat)
    Window.Section = function(self, cfg)
        -- WindUI Window:Section() returns a section object with :Tab()
        local fakeSection = {}
        fakeSection.Tab = function(self2, tabCfg)
            return Window:AddTab(tabCfg)
        end
        return fakeSection
    end

    return Window
end

