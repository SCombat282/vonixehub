            local track = frame({
                Size=UDim2.new(0,trackW,0,trackH),
                Position=UDim2.new(1,-(trackW+8),0.5,-trackH/2),
                BackgroundColor3=value and Theme.TOGGLE_ON or Theme.TOGGLE_OFF, ZIndex=2,
            }, row)
            corner(99, track); stroke(Theme.STROKE, 1, track)

            local thumb = frame({
                Size=UDim2.new(0,thumbS,0,thumbS),
                Position=value and UDim2.new(1,-(thumbS+3),0.5,-thumbS/2) or UDim2.new(0,3,0.5,-thumbS/2),
                BackgroundColor3=Theme.TEXT, ZIndex=3,
            }, track)
            corner(99, thumb)

            local function set(v, fireCallback)
