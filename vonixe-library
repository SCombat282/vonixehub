                    tween(arrow,0.15,{Rotation=0})
                    tween(menu,0.15,{Size=UDim2.new(1,0,0,0)})
                    task.delay(0.15,function() menu.Visible=false end)
                end
            end)
            row.MouseEnter:Connect(function() tween(row,0.1,{BackgroundColor3=Theme.BG3}) end)
            row.MouseLeave:Connect(function() tween(row,0.1,{BackgroundColor3=Theme.BG2}) end)

            local DdObj = {}; DdObj.Value = selected
