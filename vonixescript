local hideEffectsConn=nil
UtilsTab:AddToggle({
    Title="Hide Effects (Particles/Beams)",Value=false,
    Callback=function(state)
        if hideEffectsConn then hideEffectsConn:Disconnect(); hideEffectsConn=nil end        if state then
            local vfxPatterns={"EpicVFX_","SecretVFX_","LegendVFX_","RareVFX_","CatchVFX_","BeamHolder_","VFX_","vfx_"}
            local function isVFX(name) for _,p in ipairs(vfxPatterns) do if name:find(p,1,true) then return true end end; return false end
            
            -- Mengadopsi pola pengecekan VFX Joran dari script internal gamenya
            local rodSkinPatterns={"SKIN ROD","SKINCF","ROD","VFX","CRIMSON BUTCHER","PINK BUTCHER"}
            local function isRodSkin(v)
                local p=v.Parent
                while p and p~=game do
                    local pn=p.Name:upper()
                    for _,pat in ipairs(rodSkinPatterns) do
                        if pn:match("^SKIN ROD") or pn:find(pat,1,true) then return true end
                    end
                    p=p.Parent
                end
                return false
            end
            
            local function killEffect(v)
                pcall(function()
                    if Player.Character and v:IsDescendantOf(Player.Character) and not isRodSkin(v) then return end
                    if v:IsA("ParticleEmitter") or v:IsA("Beam") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") then v.Enabled=false end
                end)
            end
            
            -- Hancurkan RemoteEvent pemicu Gempa Kamera / Flash Putih & Orange
            pcall(function()
                local rs = game:GetService("ReplicatedStorage")
                local ex = rs:FindFirstChild("ExplosionCameraEvent")
                if ex then ex:Destroy() end
                local lg = rs:FindFirstChild("LegendCameraEvent")
                if lg then lg:Destroy() end
            end)
            
            for _,v in pairs(workspace:GetChildren()) do pcall(function() if isVFX(v.Name) then v:Destroy() end end) end
            -- Hapus rain emitter
            pcall(function()
                local cam = workspace.CurrentCamera
                if cam then
                    local rain = cam:FindFirstChild("__RainEmitter")
                    if rain then rain:Destroy() end
                end
            end)
            -- Monitor kalau rain emitter spawn lagi
            local rainConn
            rainConn = workspace.CurrentCamera.ChildAdded:Connect(function(v)
                if v.Name == "__RainEmitter" then pcall(function() v:Destroy() end) end
            end)
            local cnt=0
            for _,v in pairs(workspace:GetDescendants()) do
                pcall(function() if isVFX(v.Name) then v:Destroy() else killEffect(v) end end)
                cnt=cnt+1; if cnt%200==0 then task.wait() end
            end
            hideEffectsConn=workspace.DescendantAdded:Connect(function(v)
                pcall(function()
                    if isVFX(v.Name) then v:Destroy() else killEffect(v) end
                end)
            end)
            _N({Title="Hide Effects",Content="Aktif!",Type="Success",Duration=3})
        else
            _N({Title="Hide Effects",Content="Nonaktif. Re-join untuk restore.",Type="Info",Duration=3})
        end
    end
})

local oxygenBypassConn=nil; local oxygenHealthConn=nil; local _blurKillConn=nil
local function setupOxygenBypass()
    if oxygenHealthConn then oxygenHealthConn:Disconnect(); oxygenHealthConn=nil end
    local char=Player.Character; if not char then return end
    local hum=char:FindFirstChild("Humanoid"); if not hum then return end
    oxygenHealthConn=hum.HealthChanged:Connect(function(h) 
        if h > 0 and h < hum.MaxHealth then 
            hum.Health = hum.MaxHealth 
        end 
    end)
end

local function startBlurKill()
    if _blurKillConn then return end
    _blurKillConn=RunService.Heartbeat:Connect(function()
        if not isUnderwaterMode then
            _blurKillConn:Disconnect(); _blurKillConn=nil; return
        end
        local blur=game.Lighting:FindFirstChild("UnderwaterBlur")
        if blur and blur.Size~=0 then blur.Size=0 end
    end)
end

