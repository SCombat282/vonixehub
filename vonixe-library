        local bg2 = frame({Size=UDim2.new(1,0,1,0), BackgroundColor3=col, BackgroundTransparency=0.92, ZIndex=201}, nf)
        corner(10, bg2)
        frame({Size=UDim2.new(0,3,0.7,0), Position=UDim2.new(0,0,0.15,0), BackgroundColor3=col, ZIndex=203}, nf)

        local iconTexts = {Info="ℹ",Success="✓",Warning="⚠",Error="✕"}
        local ico = Instance.new("TextLabel")
        ico.BackgroundTransparency=1; ico.Size=UDim2.new(0,18,0,18)
        ico.Position=UDim2.new(0,12,0,13); ico.Text=iconTexts[nType] or "•"
        ico.TextColor3=col; ico.TextSize=16; ico.Font=Enum.Font.GothamBold; ico.ZIndex=203; ico.Parent=nf

        local tl = label(nTitle, isMobile and 13 or 14, Enum.Font.GothamBold, Theme.TEXT, Enum.TextXAlignment.Left, nf)
        tl.Size=UDim2.new(1,-70,0,18); tl.Position=UDim2.new(0,34,0,10); tl.ZIndex=203

        if content ~= "" then
            local cl = label(content, isMobile and 11 or 12, Enum.Font.Gotham, Theme.TEXT2, Enum.TextXAlignment.Left, nf)
            cl.Size=UDim2.new(1,-70,0,16); cl.Position=UDim2.new(0,34,0,30)
            cl.ZIndex=203; cl.TextTruncate=Enum.TextTruncate.AtEnd
            cl.TextColor3=col:Lerp(Theme.TEXT2,0.5)
        end

        local durTrack = frame({Size=UDim2.new(1,0,0,3), Position=UDim2.new(0,0,1,-3), BackgroundColor3=Color3.fromRGB(30,22,12), ZIndex=203}, nf)
        local durFill  = frame({Size=UDim2.new(1,0,1,0), BackgroundColor3=col, ZIndex=204}, durTrack)
        corner(0, durFill); gradient(col, col:Lerp(Color3.new(1,1,1),0.15), 0, durFill)

        tween(nf, 0.3, {Size=UDim2.new(1,0,0,NH)}, Enum.EasingStyle.Quint)
        local closed = false
        local function close()
            if closed then return end; closed=true
            tween(nf,0.2,{Size=UDim2.new(1,0,0,0)},Enum.EasingStyle.Quint,Enum.EasingDirection.In)
            task.delay(0.25,function() if nf and nf.Parent then nf:Destroy() end end)
        end
        task.spawn(function()
            task.wait(0.31)
            tween(durFill,dur,{Size=UDim2.new(0,0,1,0)},Enum.EasingStyle.Linear)
            task.wait(dur); close()
        end)
    end

    -- Window-level aliases
    Window.Section = function(self, cfg)
        local fakeSection = {}
        fakeSection.Tab = function(_, tabCfg) return Window:AddTab(tabCfg) end
        return fakeSection
    end

    return Window
end

