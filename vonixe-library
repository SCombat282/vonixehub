-- KEY SYSTEM
-- ================================================
function VonixeLib:CreateKeySystem(config)
    local title    = config.Title    or "Key System"
    local desc     = config.Desc     or "Enter your key to continue"
    local logoId   = config.Logo     or "rbxassetid://107213987130538"
    local onVerify = config.OnVerify
    local onGetKey = config.OnGetKey
    local verified = false

    local sg = Instance.new("ScreenGui")
    sg.Name="VonixeKeySystem"; sg.ResetOnSpawn=false
    sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; sg.IgnoreGuiInset=true; sg.DisplayOrder=9999
    pcall(function() if syn and syn.protect_gui then syn.protect_gui(sg) end; sg.Parent=game:GetService("CoreGui") end)
    if not sg.Parent or not sg.Parent.Name then sg.Parent=Player.PlayerGui end

    local vp2 = camera.ViewportSize
    local W    = isMobile and math.floor(vp2.X*0.9) or 440
    local H    = isMobile and math.floor(vp2.Y*0.55) or 320

    local function tw(obj,t,props) TweenService:Create(obj,TweenInfo.new(t,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),props):Play() end
    local function mkC(r,p) local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,r);c.Parent=p end
    local function mkG(c1,c2,rot,p) local g=Instance.new("UIGradient");g.Color=ColorSequence.new(c1,c2);g.Rotation=rot;g.Parent=p end
    local function mkF(props,p) local f=Instance.new("Frame");f.BorderSizePixel=0;for k,v in pairs(props) do f[k]=v end;f.Parent=p;return f end
    local function mkL(txt,sz,font,col,xa,p)
        local l=Instance.new("TextLabel");l.BackgroundTransparency=1;l.BorderSizePixel=0
        l.Text=txt;l.TextSize=sz;l.Font=font;l.TextColor3=col
        l.TextXAlignment=xa or Enum.TextXAlignment.Center;l.Parent=p;return l
    end

    local overlay=mkF({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.new(0,0,0),BackgroundTransparency=0.6,ZIndex=1},sg)

    local card=mkF({Size=UDim2.new(0,W,0,H),Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        BackgroundColor3=Color3.fromRGB(10,10,14),ZIndex=2,ClipsDescendants=false},sg)
    mkC(16,card)

    local bfr=mkF({Size=UDim2.new(1,4,1,4),Position=UDim2.new(0,-2,0,-2),
        BackgroundColor3=Color3.fromRGB(200,60,0),ZIndex=1},card)
    mkC(18,bfr); mkG(Color3.fromRGB(220,60,0),Color3.fromRGB(255,180,0),135,bfr)

    local inner=mkF({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(10,10,14),ZIndex=2},card)
    mkC(15,inner)

    local glow2=mkF({Size=UDim2.new(1,0,0,160),BackgroundColor3=Color3.fromRGB(200,50,0),BackgroundTransparency=0.88,ZIndex=3},inner)
    mkG(Color3.fromRGB(255,80,0),Color3.fromRGB(10,10,14),90,glow2)

    -- Close button
    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,isMobile and 36 or 28,0,isMobile and 36 or 28)
    closeBtn.Position=UDim2.new(1,-44,0,10)
    closeBtn.BackgroundColor3=Color3.fromRGB(50,20,20); closeBtn.Text="X"
    closeBtn.TextColor3=Color3.fromRGB(220,200,190); closeBtn.TextSize=isMobile and 14 or 12
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.AutoButtonColor=false
    closeBtn.BorderSizePixel=0; closeBtn.ZIndex=10; closeBtn.Parent=inner
    local cc2=Instance.new("UICorner");cc2.CornerRadius=UDim.new(0,99);cc2.Parent=closeBtn
    closeBtn.MouseEnter:Connect(function() tw(closeBtn,0.1,{BackgroundColor3=Color3.fromRGB(180,40,40)}) end)
    closeBtn.MouseLeave:Connect(function() tw(closeBtn,0.1,{BackgroundColor3=Color3.fromRGB(50,20,20)}) end)

    local logoFrame=mkF({Size=UDim2.new(0,56,0,56),Position=UDim2.new(0.5,-28,0,16),
        BackgroundColor3=Color3.fromRGB(18,12,8),ZIndex=4},inner)
    mkC(99,logoFrame)
    local ls2=Instance.new("UIStroke");ls2.Color=Color3.fromRGB(220,80,0);ls2.Thickness=2;ls2.Parent=logoFrame
    local li2=Instance.new("ImageLabel");li2.Size=UDim2.new(1,0,1,0);li2.BackgroundTransparency=1
    li2.Image=logoId;li2.ScaleType=Enum.ScaleType.Fit;li2.ZIndex=5;li2.Parent=logoFrame

    local t4=0
    local pc2=RunService.Heartbeat:Connect(function(dt)
        t4=t4+dt*2; local a=(math.sin(t4)+1)/2
        ls2.Color=Color3.fromRGB(220,60,0):Lerp(Color3.fromRGB(255,200,50),a*0.6)
    end)

    closeBtn.MouseButton1Click:Connect(function()
        pc2:Disconnect()
        tw(card,0.25,{Size=UDim2.new(0,W,0,0)})
        tw(overlay,0.25,{BackgroundTransparency=1})
        task.wait(0.3); sg:Destroy()
    end)

    local titleLbl2=mkL(title,isMobile and 18 or 20,Enum.Font.GothamBlack,Color3.new(1,1,1),Enum.TextXAlignment.Center,inner)
    titleLbl2.Size=UDim2.new(1,0,0,24); titleLbl2.Position=UDim2.new(0,0,0,80); titleLbl2.ZIndex=4

    local descLbl2=mkL(desc,isMobile and 10 or 11,Enum.Font.Gotham,Color3.fromRGB(140,120,100),Enum.TextXAlignment.Center,inner)
    descLbl2.Size=UDim2.new(1,-40,0,14); descLbl2.Position=UDim2.new(0,20,0,108); descLbl2.ZIndex=4

    local div2=mkF({Size=UDim2.new(0,180,0,1),Position=UDim2.new(0.5,-90,0,128),BackgroundColor3=Color3.fromRGB(200,60,0),ZIndex=4},inner)
    mkG(Color3.fromRGB(200,60,0),Color3.fromRGB(255,180,0),0,div2)

    local inputBg2=mkF({Size=UDim2.new(1,-40,0,isMobile and 48 or 42),Position=UDim2.new(0,20,0,138),
        BackgroundColor3=Color3.fromRGB(16,12,10),ZIndex=4},inner)
    mkC(10,inputBg2)
    local is2=Instance.new("UIStroke");is2.Color=Color3.fromRGB(60,40,20);is2.Thickness=1;is2.Parent=inputBg2

    local inputBox2=Instance.new("TextBox")
    inputBox2.Size=UDim2.new(1,-20,1,0); inputBox2.Position=UDim2.new(0,10,0,0)
    inputBox2.BackgroundTransparency=1; inputBox2.Text=""
    inputBox2.PlaceholderText="Paste key kamu di sini..."
    inputBox2.PlaceholderColor3=Color3.fromRGB(80,65,50); inputBox2.TextColor3=Color3.new(1,1,1)
    inputBox2.TextSize=isMobile and 12 or 13; inputBox2.Font=Enum.Font.Gotham
    inputBox2.TextXAlignment=Enum.TextXAlignment.Left; inputBox2.ClearTextOnFocus=false
    inputBox2.ZIndex=5; inputBox2.Parent=inputBg2
    inputBox2.Focused:Connect(function() tw(is2,0.15,{Color=Color3.fromRGB(200,100,0)}) end)
    inputBox2.FocusLost:Connect(function() tw(is2,0.15,{Color=Color3.fromRGB(60,40,20)}) end)

    local statusLbl2=mkL("",11,Enum.Font.GothamBold,Color3.fromRGB(255,220,50),Enum.TextXAlignment.Center,inner)
    statusLbl2.Size=UDim2.new(1,-40,0,14); statusLbl2.Position=UDim2.new(0,20,0,194); statusLbl2.ZIndex=4

    local function makeBtn2(txt,x,bw,bg,hover)
        local btn=Instance.new("TextButton")
        btn.Size=UDim2.new(0,bw,0,isMobile and 40 or 34); btn.Position=UDim2.new(0,x,0,216)
        btn.BackgroundColor3=bg; btn.Text=""; btn.AutoButtonColor=false
        btn.BorderSizePixel=0; btn.ZIndex=4; btn.Parent=inner
        mkC(8,btn)
        local lbl=mkL(txt,isMobile and 12 or 13,Enum.Font.GothamBold,Color3.new(1,1,1),Enum.TextXAlignment.Center,btn)
        lbl.Size=UDim2.new(1,0,1,0); lbl.ZIndex=5
        btn.MouseEnter:Connect(function() tw(btn,0.1,{BackgroundColor3=hover}) end)
        btn.MouseLeave:Connect(function() tw(btn,0.1,{BackgroundColor3=bg}) end)
        return btn,lbl
    end

    local bW2=(W-48-8)/2
    local verifyBtn,verifyLbl=makeBtn2("Verifikasi Key",24,bW2,Color3.fromRGB(180,60,0),Color3.fromRGB(220,80,0))
    local getkeyBtn,_=makeBtn2("Dapatkan Key",24+bW2+8,bW2,Color3.fromRGB(30,22,14),Color3.fromRGB(50,35,18))
    local gks2=Instance.new("UIStroke");gks2.Color=Color3.fromRGB(80,50,20);gks2.Thickness=1;gks2.Parent=getkeyBtn

    verifyBtn.MouseButton1Click:Connect(function()
        local key=inputBox2.Text
        if key=="" then
            statusLbl2.Text="Key tidak boleh kosong!"; statusLbl2.TextColor3=Color3.fromRGB(255,80,80)
            tw(inputBg2,0.1,{BackgroundColor3=Color3.fromRGB(30,10,10)})
            task.delay(0.2,function() tw(inputBg2,0.15,{BackgroundColor3=Color3.fromRGB(16,12,10)}) end)
            return
        end
        statusLbl2.Text="Memverifikasi..."; statusLbl2.TextColor3=Color3.fromRGB(255,220,50)
        verifyLbl.Text="..."
        task.spawn(function()
            local ok2=false
            if onVerify then local s,r=pcall(onVerify,key); ok2=s and r end
            if ok2 then
                statusLbl2.Text="Key valid!"; statusLbl2.TextColor3=Color3.fromRGB(80,220,120)
                verifyLbl.Text="✓"; tw(verifyBtn,0.2,{BackgroundColor3=Color3.fromRGB(30,120,60)})
                tw(card,0.4,{BackgroundTransparency=1}); tw(overlay,0.4,{BackgroundTransparency=1})
                task.wait(0.8); pc2:Disconnect(); sg:Destroy(); verified=true
            else
                statusLbl2.Text="Key tidak valid atau expired!"; statusLbl2.TextColor3=Color3.fromRGB(255,80,80)
                verifyLbl.Text="Verifikasi Key"
                tw(inputBg2,0.1,{BackgroundColor3=Color3.fromRGB(30,10,10)})
                task.delay(0.3,function() tw(inputBg2,0.2,{BackgroundColor3=Color3.fromRGB(16,12,10)}) end)
            end
        end)
    end)
    getkeyBtn.MouseButton1Click:Connect(function()
        if onGetKey then pcall(onGetKey) end
        statusLbl2.Text="Link sudah dibuka!"; statusLbl2.TextColor3=Color3.fromRGB(80,220,120)
        task.delay(3,function() if statusLbl2 and statusLbl2.Parent then statusLbl2.Text="" end end)
    end)

    card.Size=UDim2.new(0,W,0,0)
    tw(card,0.4,{Size=UDim2.new(0,W,0,H)})

    while not verified do task.wait(0.1) end
end

return VonixeLib
