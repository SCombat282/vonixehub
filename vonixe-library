-- ICON SYSTEM
-- ================================================
local Icons = nil
pcall(function()
    local HttpService = game:GetService("HttpService")
    local src = game:HttpGetAsync
        and game:HttpGetAsync("https://raw.githubusercontent.com/Footagesus/Icons/main/Main-v2.lua")
        or HttpService:GetAsync("https://raw.githubusercontent.com/Footagesus/Icons/main/Main-v2.lua")
    local lib = loadstring(src)()
    lib.SetIconsType("lucide")
    Icons = lib
end)

local function getIcon(name)
    if not Icons then return nil end
    local ok, r = pcall(function() return Icons.Icon(name) end)
    if ok and r and type(r) == "table" then return r end
    return nil
end

local textFallback = {
    ["x"]="X",["minus"]="—",["chevron-right"]="›",["chevron-down"]="⌄",
    ["check-circle"]="✓",["x-circle"]="✕",["triangle-alert"]="!",["info"]="i",
    ["bell"]="🔔",["activity"]="≋",["fish"]="≋",["settings"]="⚙",
    ["map-pin"]="◎",["shopping-cart"]="🛒",["layout-dashboard"]="⊞",
}

local function mkIcon(name, size, col, parent, zindex)
    local container = Instance.new("Frame")
    container.BackgroundTransparency = 1
    container.Size   = UDim2.new(0, size, 0, size)
    container.ZIndex = zindex or 2
    container.Parent = parent

    local img = Instance.new("ImageLabel")
    img.BackgroundTransparency = 1
    img.Size        = UDim2.new(1, 0, 1, 0)
    img.ZIndex      = (zindex or 2) + 1
    img.ImageColor3 = col or Color3.new(1,1,1)
    img.ScaleType   = Enum.ScaleType.Fit
    img.Parent      = container

    local function applyIcon()
        if not Icons then return false end
        local r = getIcon(name)
        if not r then return false end
        img.Image = r[1] or ""
        local data = r[2]
        if data then
            local rs = data.ImageRectSize
            local rp = data.ImageRectPosition
            if rs and rs.X > 0 then
                img.ImageRectSize   = rs
                img.ImageRectOffset = rp or Vector2.new(0,0)
            else
                img.ImageRectSize   = Vector2.new(0,0)
                img.ImageRectOffset = Vector2.new(0,0)
            end
        end
        return img.Image ~= ""
    end

    local function useFallback()
        pcall(function() img:Destroy() end)
        local txt = Instance.new("TextLabel")
        txt.BackgroundTransparency = 1
        txt.Size           = UDim2.new(1, 0, 1, 0)
        txt.ZIndex         = (zindex or 2) + 1
        txt.TextColor3     = col or Color3.new(1,1,1)
        txt.Text           = textFallback[name] or "•"
        txt.TextSize       = math.max(size - 2, 10)
        txt.Font           = Enum.Font.GothamBold
        txt.TextXAlignment = Enum.TextXAlignment.Center
        txt.TextYAlignment = Enum.TextYAlignment.Center
        txt.Parent         = container
    end

    local applied = applyIcon()
    task.spawn(function()
        if not applied then
            for _ = 1, 15 do
                task.wait(0.2)
                if applyIcon() then return end
            end
            if container and container.Parent then useFallback() end
        end
    end)
    return container
end

