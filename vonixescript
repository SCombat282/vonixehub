local autoMissionThread=nil; local sharedMissionState=nil
local autoMissionSubtext=""

local function getMissionState()
    local ok,r=pcall(function() return ReplicatedStorage:WaitForChild("MissionSystem",5):WaitForChild("ToServer",5):WaitForChild("GetMissionState",5):InvokeServer() end)
    if ok and type(r)=="table" then return r end; return nil
end

local evoZoneMap={TIRAN="BALI", CHORMA="BANDA", KRYO="OPEN_OCEAN"}

local function getActiveRequirement(state)
    if not state then return nil end
    local reqs=state.MissionDef and state.MissionDef.Requirements
    local prereqs=state.MissionDef and state.MissionDef.Prerequisites
    local prog=state.Progress; if not prog then return nil end
    local totalReqs=reqs and #reqs or 0
    if reqs then
        for i=1,#reqs do
            local req=reqs[i]; local current=prog[req.key] or 0
            if current<req.count then
                if (not req.zone or req.zone=="") and req.evoType then
                    local ez=evoZoneMap[req.evoType:upper()]
                    if ez then
                        local r2={}; for k,v in pairs(req) do r2[k]=v end
                        r2.zone=ez; return r2,current,i,totalReqs
                    end
                end
                return req,current,i,totalReqs
            end
        end
    end
    if prereqs and prereqs.megalodonFish and prereqs.megalodonFish>0 then
        local mc=tonumber(state.MegalodonCatchCount) or 0; local mt=tonumber(prereqs.megalodonFish) or 0
        if mc<mt then return {key="MEGALODON_FISH",tier="MEGALODON",zone="MEGALODON",count=mt},mc,totalReqs+1,totalReqs+1 end
    end
    return nil
end

local missionMonitorLabel=nil

local function activateMegalodonZone()
    local mr=ReplicatedStorage:WaitForChild("MegalodonZone",5); if not mr then return false end
    local isActive=false
    pcall(function() local s=mr:WaitForChild("GetZoneStatus",5):InvokeServer(); if type(s)=="boolean" then isActive=s elseif type(s)=="table" then isActive=s.IsActive or s.isActive or s.Active or false end end)
    if isActive then _N({Title="Megalodon Zone",Content="Zone sudah aktif!",Type="Success",Duration=3}); return true end
    _N({Title="Megalodon Zone",Content="Mengaktifkan 150.000 CF...",Type="Info",Duration=3})
    local ok,err=pcall(function() mr:WaitForChild("ActivateWithCF",5):InvokeServer() end)
    if not ok then _N({Title="Megalodon Zone",Content="Gagal: "..tostring(err),Type="Error",Duration=5}); return false end
    local w=0
    while w<10 do
        task.wait(1); w=w+1
        pcall(function() local s=mr:WaitForChild("GetZoneStatus",5):InvokeServer(); if type(s)=="boolean" then isActive=s elseif type(s)=="table" then isActive=s.IsActive or s.isActive or s.Active or false end end)
        if isActive then break end
    end
    if isActive then _N({Title="Megalodon Zone",Content="Zone aktif!",Type="Success",Duration=3}); return true
    else _N({Title="Megalodon Zone",Content="Tidak aktif setelah 10 detik!",Type="Error",Duration=5}); return false end
end

local function runAutoMission()
    local lastZone=nil

    while isAutoMission do
        pcall(function()
            local state=getMissionState()
            if not state then task.wait(3); return end
            sharedMissionState=state

            local req,current,idx,total=getActiveRequirement(state)
            if not req then
                _N({Title="Auto Mission",Content="Semua task selesai!",Type="Success",Duration=5})
                isAutoMission=false; isAutoStone=false; setCharFreeze(false); lastZone=nil
                if missionMonitorLabel then missionMonitorLabel:SetTitle("Mission: SELESAI") end; return
            end

            local stoneType=isAutoStone and detectStoneType(req) or nil
            local needsStone=stoneType~=nil and reqNeedsStone(req)
            local zone=req.zone
            if (not zone or zone=="" or zone=="nil") and needsStone and stoneType then
                zone=stoneConfig[stoneType].zoneName:upper():gsub(" ","_")
            end
            zone=zone and zone:upper():gsub("%s+","_"):gsub("[^%w_]","") or "UNKNOWN"
            local zoneData=getZoneData(zone)
            if not zoneData and needsStone and stoneType then
                zoneData={cf=stoneConfig[stoneType].zoneCF, freeze=true}
            end

            -- Debug removed

            if missionMonitorLabel then
                if autoMissionSubtext ~= "" then
                    missionMonitorLabel:SetTitle("RAW:" .. autoMissionSubtext)
                else
                    local si=stoneType and (" ["..stoneType.."]") or ""
                    missionMonitorLabel:SetTitle(string.format("[%d/%d] %s @ %s | %d/%d%s",idx,total,req.tier or "?",zone,current,req.count,si))
                end
            end

            if zone~=lastZone then
                if not isAutoMission then return end
                if zoneData then
                    setCharFreeze(false)
                    if zoneData.preAction=="megalodon" then
                        if not activateMegalodonZone() then lastZone=zone; return end
                    end
                    if needsStone then
                        -- Ada stone requirement: stone handler yang urus TP + gacha + aktivasi
                        lastZone=zone
                        _N({Title="Auto Stone",Content="Butuh "..stoneType.." stone, cek...",Type="Warning",Duration=3})
                        task.spawn(function() handleStoneMission(stoneType,activeSessionId,zoneData.cf) end)
                    else
                        -- Tidak butuh stone: langsung TP ke zone misi
                        tpTo(zoneData.cf); lastZone=zone
                        task.wait(0.05)
                        if not isAutoMission then setCharFreeze(false); return end
                        pcall(function()
                            local hrp=Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                            if hrp then hrp.CFrame=zoneData.cf; hrp.Velocity=Vector3.new(0,0,0); hrp.RotVelocity=Vector3.new(0,0,0); frozenCFrame=zoneData.cf end
                        end)
                        if zoneData.freeze then setCharFreeze(true) end
                        _N({Title="Auto Mission",Content=string.format("[%d/%d] %s @ %s | %d/%d",idx,total,req.tier or "?",zone,current,req.count),Type="Info",Duration=4})
                    end
                else
                    _N({Title="Zone Missing",Content="Zone: '"..zone.."' Raw: '"..tostring(req.zone).."'",Type="Error",Duration=10})
                    lastZone=zone
                end
            end
        end)
        task.wait(2)
    end
    setCharFreeze(false)
end

