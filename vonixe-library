function VonixeLib:CreateKeySystem(config)
    local title    = config.Title    or "Key System"
    local desc     = config.Desc     or "Enter your key to continue"
    local logoId   = config.Logo     or "rbxassetid://107213987130538"
    local onVerify = config.OnVerify
    local onGetKey = config.OnGetKey
    local verified = false

    local vp2 = camera.ViewportSize
    local W = isMobile and math.floor(vp2.X*0.88) or 440
    local H = isMobile and math.floor(vp2.Y*0.52) or 320

    local sg = Instance.new("ScreenGui")
    sg.Name="VonixeKeySystem"; sg.ResetOnSpawn=false
    sg.ZIndexBehavior=Enum.ZIndexBehavior.Sibling; sg.IgnoreGuiInset=true; sg.DisplayOrder=9999
    pcall(function()
        local syn=syn or {}; if syn.protect_gui then syn.protect_gui(sg) end
        sg.Parent=game:GetService("CoreGui")
    end)
    if not sg.Parent or not sg.Parent.Name then sg.Parent=Player.PlayerGui end

    local function tw(obj,t,props) TweenService:Create(obj,TweenInfo.new(t,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),props):Play() end
    local function mkC(r,p) local c=Instance.new("UICorner");c.CornerRadius=UDim.new(0,r);c.Parent=p end
    local function mkG(c1,c2,rot,p) local g=Instance.new("UIGradient");g.Color=ColorSequence.new(c1,c2);g.Rotation=rot;g.Parent=p end
    local function mkF(props,p) local f=Instance.new("Frame");f.BorderSizePixel=0;for k,v in pairs(props) do f[k]=v end;f.Parent=p;return f end
    local function mkL(txt,sz,font,col,xa,p)
        local l=Instance.new("TextLabel");l.BackgroundTransparency=1;l.BorderSizePixel=0
        l.Text=txt;l.TextSize=sz;l.Font=font;l.TextColor3=col
        l.TextXAlignment=xa or Enum.TextXAlignment.Center;l.Parent=p;return l
    end

    local overlay=mkF({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(0,0,0),BackgroundTransparency=0.6,ZIndex=1},sg)
    local card=mkF({Size=UDim2.new(0,W,0,H),Position=UDim2.new(0.5,-W/2,0.5,-H/2),
        BackgroundColor3=Color3.fromRGB(10,10,14),ZIndex=2,ClipsDescendants=false},sg)
    mkC(16,card)
    local bfr=mkF({Size=UDim2.new(1,4,1,4),Position=UDim2.new(0,-2,0,-2),BackgroundColor3=Color3.fromRGB(200,60,0),ZIndex=1},card)
    mkC(18,bfr); mkG(Color3.fromRGB(220,60,0),Color3.fromRGB(255,180,0),135,bfr)
    local inner=mkF({Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(10,10,14),ZIndex=2},card)
    mkC(15,inner)
    local glow=mkF({Size=UDim2.new(1,0,0,160),BackgroundColor3=Color3.fromRGB(200,50,0),BackgroundTransparency=0.88,ZIndex=3},inner)
    mkG(Color3.fromRGB(255,80,0),Color3.fromRGB(10,10,14),90,glow)

    local closeBtn=Instance.new("TextButton")
    closeBtn.Size=UDim2.new(0,isMobile and 34 or 28,0,isMobile and 34 or 28)
    closeBtn.Position=UDim2.new(1,-40,0,10); closeBtn.BackgroundColor3=Color3.fromRGB(50,20,20)
    closeBtn.Text="X"; closeBtn.TextColor3=Color3.fromRGB(220,200,190); closeBtn.TextSize=12
    closeBtn.Font=Enum.Font.GothamBold; closeBtn.AutoButtonColor=false
    closeBtn.BorderSizePixel=0; closeBtn.ZIndex=10; closeBtn.Parent=inner
    mkC(99,closeBtn)
    closeBtn.MouseEnter:Connect(function() tw(closeBtn,0.1,{BackgroundColor3=Color3.fromRGB(180,40,40)}) end)
    closeBtn.MouseLeave:Connect(function() tw(closeBtn,0.1,{BackgroundColor3=Color3.fromRGB(50,20,20)}) end)

    local logoFrame=mkF({Size=UDim2.new(0,64,0,64),Position=UDim2.new(0.5,-32,0,20),
        BackgroundColor3=Color3.fromRGB(18,12,8),ZIndex=4},inner)
    mkC(99,logoFrame)
    local logoStroke=Instance.new("UIStroke");logoStroke.Color=Color3.fromRGB(220,80,0);logoStroke.Thickness=2;logoStroke.Parent=logoFrame
    local logoImg=Instance.new("ImageLabel");logoImg.Size=UDim2.new(1,0,1,0);logoImg.BackgroundTransparency=1
    logoImg.Image=logoId;logoImg.ScaleType=Enum.ScaleType.Fit;logoImg.ZIndex=5;logoImg.Parent=logoFrame

    local t2=0
    local pulseConn=RunService.Heartbeat:Connect(function(dt)
        t2=t2+dt*2; local a=(math.sin(t2)+1)/2
        logoStroke.Color=Color3.fromRGB(220,60,0):Lerp(Color3.fromRGB(255,200,50),a*0.6)
    end)

    closeBtn.MouseButton1Click:Connect(function()
        pulseConn:Disconnect()
        tw(card,0.25,{Size=UDim2.new(0,W,0,0)}); tw(overlay,0.25,{BackgroundTransparency=1})
        task.wait(0.3); sg:Destroy()
    end)

    local titleLbl=mkL(title,isMobile and 18 or 20,Enum.Font.GothamBlack,Color3.fromRGB(255,255,255),Enum.TextXAlignment.Center,inner)
    titleLbl.Size=UDim2.new(1,0,0,24); titleLbl.Position=UDim2.new(0,0,0,92); titleLbl.ZIndex=4
    local descLbl=mkL(desc,isMobile and 10 or 11,Enum.Font.Gotham,Color3.fromRGB(140,120,100),Enum.TextXAlignment.Center,inner)
    descLbl.Size=UDim2.new(1,-40,0,14); descLbl.Position=UDim2.new(0,20,0,118); descLbl.ZIndex=4
    local div=mkF({Size=UDim2.new(0,180,0,1),Position=UDim2.new(0.5,-90,0,140),BackgroundColor3=Color3.fromRGB(200,60,0),ZIndex=4},inner)
    mkG(Color3.fromRGB(200,60,0),Color3.fromRGB(255,180,0),0,div)

    local inputBg=mkF({Size=UDim2.new(1,-48,0,isMobile and 46 or 42),Position=UDim2.new(0,24,0,152),
        BackgroundColor3=Color3.fromRGB(16,12,10),ZIndex=4},inner)
    mkC(10,inputBg)
    local inputStroke=Instance.new("UIStroke");inputStroke.Color=Color3.fromRGB(60,40,20);inputStroke.Thickness=1;inputStroke.Parent=inputBg
    local inputBox=Instance.new("TextBox")
    inputBox.Size=UDim2.new(1,-20,1,0); inputBox.Position=UDim2.new(0,10,0,0)
    inputBox.BackgroundTransparency=1; inputBox.Text=""; inputBox.PlaceholderText="Paste key kamu di sini..."
    inputBox.PlaceholderColor3=Color3.fromRGB(80,65,50); inputBox.TextColor3=Color3.fromRGB(255,255,255)
    inputBox.TextSize=isMobile and 12 or 13; inputBox.Font=Enum.Font.Gotham
    inputBox.TextXAlignment=Enum.TextXAlignment.Left; inputBox.ClearTextOnFocus=false
    inputBox.ZIndex=5; inputBox.Parent=inputBg
    inputBox.Focused:Connect(function() tw(inputStroke,0.15,{Color=Color3.fromRGB(200,100,0)}) end)
    inputBox.FocusLost:Connect(function() tw(inputStroke,0.15,{Color=Color3.fromRGB(60,40,20)}) end)

    local statusLbl2=mkL("",11,Enum.Font.GothamBold,Color3.fromRGB(255,220,50),Enum.TextXAlignment.Center,inner)
    statusLbl2.Size=UDim2.new(1,-40,0,14); statusLbl2.Position=UDim2.new(0,20,0,206); statusLbl2.ZIndex=4

    local function makeBtn(txt,x,w,bg,hover)
        local btn=Instance.new("TextButton")
        btn.Size=UDim2.new(0,w,0,isMobile and 38 or 34); btn.Position=UDim2.new(0,x,0,228)
        btn.BackgroundColor3=bg; btn.Text=""; btn.AutoButtonColor=false
        btn.BorderSizePixel=0; btn.ZIndex=4; btn.Parent=inner; mkC(8,btn)
        local lbl3=mkL(txt,isMobile and 12 or 13,Enum.Font.GothamBold,Color3.fromRGB(255,255,255),Enum.TextXAlignment.Center,btn)
        lbl3.Size=UDim2.new(1,0,1,0); lbl3.ZIndex=5
        btn.MouseEnter:Connect(function() tw(btn,0.1,{BackgroundColor3=hover}) end)
        btn.MouseLeave:Connect(function() tw(btn,0.1,{BackgroundColor3=bg}) end)
        return btn,lbl3
    end

    local bW=(W-48-8)/2
    local verifyBtn,verifyLbl=makeBtn("Verifikasi Key",24,bW,Color3.fromRGB(180,60,0),Color3.fromRGB(220,80,0))
    local getkeyBtn,_=makeBtn("Dapatkan Key",24+bW+8,bW,Color3.fromRGB(30,22,14),Color3.fromRGB(50,35,18))
    local gks=Instance.new("UIStroke");gks.Color=Color3.fromRGB(80,50,20);gks.Thickness=1;gks.Parent=getkeyBtn
    local vAcc=mkF({Size=UDim2.new(1,0,0,2),BackgroundColor3=Color3.fromRGB(220,80,0),ZIndex=5},verifyBtn)
    mkG(Color3.fromRGB(200,60,0),Color3.fromRGB(255,200,0),0,vAcc)

    verifyBtn.MouseButton1Click:Connect(function()
        local key=inputBox.Text
        if key=="" then
            statusLbl2.Text="Key tidak boleh kosong!"; statusLbl2.TextColor3=Color3.fromRGB(255,80,80)
            tw(inputBg,0.1,{BackgroundColor3=Color3.fromRGB(30,10,10)})
            task.delay(0.2,function() tw(inputBg,0.15,{BackgroundColor3=Color3.fromRGB(16,12,10)}) end); return
        end
        statusLbl2.Text="Memverifikasi..."; statusLbl2.TextColor3=Color3.fromRGB(255,220,50); verifyLbl.Text="..."
        task.spawn(function()
            local ok3=false
            if onVerify then local s,r=pcall(onVerify,key); ok3=s and r end
            if ok3 then
                statusLbl2.Text="Key valid!"; statusLbl2.TextColor3=Color3.fromRGB(80,220,120)
                verifyLbl.Text="✓"; tw(verifyBtn,0.2,{BackgroundColor3=Color3.fromRGB(30,120,60)})
                tw(card,0.4,{BackgroundTransparency=1}); tw(overlay,0.4,{BackgroundTransparency=1})
                task.wait(0.8); pulseConn:Disconnect(); sg:Destroy(); verified=true
            else
                statusLbl2.Text="Key tidak valid atau expired!"; statusLbl2.TextColor3=Color3.fromRGB(255,80,80)
                verifyLbl.Text="Verifikasi Key"
                tw(inputBg,0.1,{BackgroundColor3=Color3.fromRGB(30,10,10)})
                task.delay(0.3,function() tw(inputBg,0.2,{BackgroundColor3=Color3.fromRGB(16,12,10)}) end)
            end
        end)
    end)
    getkeyBtn.MouseButton1Click:Connect(function()
        if onGetKey then pcall(onGetKey) end
        statusLbl2.Text="Link sudah tercopy ke clipboard!"; statusLbl2.TextColor3=Color3.fromRGB(80,220,120)
        task.delay(3,function() if statusLbl2 and statusLbl2.Parent then statusLbl2.Text="" end end)
    end)

    card.Size=UDim2.new(0,W,0,0); tw(card,0.4,{Size=UDim2.new(0,W,0,H)})
    while not verified do task.wait(0.1) end
end

return VonixeLib
