            function DdObj:SetTitle(t) nameLbl.Text=t end
            function DdObj:Refresh(newOptions)
                for _, b in ipairs(optBtns) do b:Destroy() end
                optBtns={}; options=newOptions; menuH=#options*optH
                for _, opt in ipairs(newOptions) do makeOptBtn(opt) end
            end
            return DdObj
        end

