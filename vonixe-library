function VonixeLib:CreateWindow(config)
    local title    = config.Title or "VonixeLib"
    local subtitle = config.Subtitle or ""

    -- ── Ukuran adaptif mobile ──────────────────────
    local vp     = camera.ViewportSize
    local BASE_W = 560
    local BASE_H = 420

    -- Mobile: ambil hampir seluruh layar (92%)
    -- Desktop: ukuran normal
    local W, H, sideW
    if isMobile then
        W     = math.floor(vp.X * 0.92)
        H     = math.floor(vp.Y * 0.82)
        sideW = math.min(130, math.floor(W * 0.27))
    else
        W     = config.Width or BASE_W
        H     = config.Height or BASE_H
        sideW = config.SidebarWidth or 160
    end

    local Window = {}
    Window._tabs     = {}
    Window._selected = nil

    -- ScreenGui
    local sg = Instance.new("ScreenGui")
    sg.Name           = "VonixeLib_" .. title
    sg.ResetOnSpawn   = false
    sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    sg.IgnoreGuiInset = true
    sg.DisplayOrder   = 999
    local ok = pcall(function()
        if syn and syn.protect_gui then syn.protect_gui(sg) end
        sg.Parent = game:GetService("CoreGui")
    end)
    if not ok then sg.Parent = Player.PlayerGui end
    Window._sg = sg

    -- Main frame — posisi tengah layar, NO UIScale
    -- Mobile langsung pakai ukuran absolut yang pas
    local main = frame({
        Size             = UDim2.new(0, W, 0, H),
        Position         = UDim2.new(0.5, -W/2, 0.5, -H/2),
        BackgroundColor3 = Theme.BG,
        ClipsDescendants = false,
        ZIndex           = 1,
    }, sg)
    corner(14, main)
    Window._main = main

    -- Re-center saat viewport berubah (rotate HP, resize PC)
    camera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        local newVP = camera.ViewportSize
        if isMobile then
            local newW = math.floor(newVP.X * 0.92)
            local newH = math.floor(newVP.Y * 0.82)
            -- Hanya resize kalau belum di-drag user
            tween(main, 0.2, {
                Size     = UDim2.new(0, newW, 0, newH),
                Position = UDim2.new(0, (newVP.X - newW)/2, 0, (newVP.Y - newH)/2)
            })
        else
            -- Desktop: cukup re-center saja
            main.Position = UDim2.new(0.5, -W/2, 0.5, -H/2)
        end
    end)

    -- Gradient border
    local bfr = frame({
        Size=UDim2.new(1,4,1,4), Position=UDim2.new(0,-2,0,-2),
        BackgroundColor3=Theme.ACCENT1, ZIndex=0,
    }, main)
    corner(16, bfr)
    gradient(Theme.ACCENT1, Theme.ACCENT2, 135, bfr)

    -- Inner bg
    local bgo = frame({
        Size=UDim2.new(1,0,1,0), BackgroundColor3=Theme.BG,
        ZIndex=1, ClipsDescendants=true,
    }, main)
    corner(13, bgo)

    -- Top glow
    local topGlow = frame({
        Size=UDim2.new(1,0,0,120), BackgroundColor3=Theme.ACCENT1,
        BackgroundTransparency=0.92, ZIndex=2,
    }, bgo)
    gradient(Color3.fromRGB(255,80,0), Theme.BG, 90, topGlow)

    -- ── HEADER ─────────────────────────────────────
    local headerH = isMobile and 48 or 54
    local header = frame({
        Size=UDim2.new(1,0,0,headerH), BackgroundTransparency=1, ZIndex=5,
    }, bgo)

    local dot = frame({
        Size=UDim2.new(0,8,0,8), Position=UDim2.new(0,14,0.5,-4),
        BackgroundColor3=Theme.ACCENT1, ZIndex=6,
    }, header)
    corner(99, dot)

    local titleLbl = label(title, isMobile and 13 or 15, Enum.Font.GothamBlack, Theme.TEXT, Enum.TextXAlignment.Left, header)
    titleLbl.Size     = UDim2.new(1, -90, 0, 20)
    titleLbl.Position = UDim2.new(0, 30, 0.5, -10)
    titleLbl.ZIndex   = 6

    if subtitle ~= "" then
        local subLbl = label(subtitle, 9, Enum.Font.GothamBold, Theme.ACCENT2, Enum.TextXAlignment.Left, header)
        subLbl.Size     = UDim2.new(1, -90, 0, 12)
        subLbl.Position = UDim2.new(0, 30, 0.5, 2)
        subLbl.ZIndex   = 6
    end

    -- Icon buttons kanan header
    local iconBtnSize = isMobile and 32 or 28
    local iconBtnY    = (headerH/2) - (iconBtnSize/2)

    local function makeIconBtn(xOffset, iconName, bgCol, hoverCol)
        local btn = Instance.new("TextButton")
        btn.Size            = UDim2.new(0, iconBtnSize, 0, iconBtnSize)
        btn.Position        = UDim2.new(1, xOffset, 0, iconBtnY)
        btn.BackgroundColor3 = bgCol
        btn.Text            = ""
        btn.AutoButtonColor = false
        btn.BorderSizePixel = 0
        btn.ZIndex          = 10
        btn.Parent          = bgo
        corner(99, btn)
        local ico = mkIcon(iconName, 14, Color3.fromRGB(220,200,190), btn, 11)
        ico.AnchorPoint = Vector2.new(0.5, 0.5)
        ico.Position    = UDim2.new(0.5, 0, 0.5, 0)
        ico.Size        = UDim2.new(0, 14, 0, 14)
        local function setColor(col)
            local inner = ico:FindFirstChildWhichIsA("ImageLabel") or ico:FindFirstChildWhichIsA("TextLabel")
            if inner then
                if inner:IsA("ImageLabel") then tween(inner,0.1,{ImageColor3=col})
                else tween(inner,0.1,{TextColor3=col}) end
            end
        end
        btn.MouseEnter:Connect(function() tween(btn,0.1,{BackgroundColor3=hoverCol}); setColor(Color3.new(1,1,1)) end)
        btn.MouseLeave:Connect(function() tween(btn,0.1,{BackgroundColor3=bgCol}); setColor(Color3.fromRGB(220,200,190)) end)
        return btn
    end

    local gap = isMobile and 40 or 36
    local closeBtn = makeIconBtn(-gap,    "x",     Color3.fromRGB(50,20,20),  Color3.fromRGB(180,40,40))
    local minBtn   = makeIconBtn(-gap*2+4,"minus",  Color3.fromRGB(35,28,10),  Color3.fromRGB(100,70,10))

    closeBtn.MouseButton1Click:Connect(function() sg:Destroy() end)

    -- Floating restore button
    local restoreBtn = Instance.new("ImageButton")
    restoreBtn.Size             = UDim2.new(0, isMobile and 58 or 52, 0, isMobile and 58 or 52)
    restoreBtn.Position         = UDim2.new(0.5, -26, 0, 12)
    restoreBtn.BackgroundColor3 = Color3.fromRGB(18,12,6)
    restoreBtn.BorderSizePixel  = 0
    restoreBtn.Image            = "rbxassetid://107213987130538"
    restoreBtn.ImageColor3      = Color3.fromRGB(255,255,255)
    restoreBtn.ScaleType        = Enum.ScaleType.Fit
    restoreBtn.Visible          = false
    restoreBtn.ZIndex           = 50
    restoreBtn.Active           = true
    restoreBtn.Parent           = sg
    corner(99, restoreBtn)
    local glowStroke = Instance.new("UIStroke")
    glowStroke.Color=Theme.ACCENT1; glowStroke.Thickness=2; glowStroke.Parent=restoreBtn
    restoreBtn.MouseEnter:Connect(function()
        tween(restoreBtn,0.15,{BackgroundColor3=Color3.fromRGB(35,22,8)})
        tween(glowStroke,0.15,{Color=Theme.ACCENT2})
    end)
    restoreBtn.MouseLeave:Connect(function()
        tween(restoreBtn,0.15,{BackgroundColor3=Color3.fromRGB(18,12,6)})
        tween(glowStroke,0.15,{Color=Theme.ACCENT1})
    end)
    -- Restore button draggable (touch + mouse)
    local rbDragging,rbDragStart,rbStartPos = false,nil,nil
    local rbMoved = false
    restoreBtn.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            rbDragging=true; rbDragStart=i.Position; rbStartPos=restoreBtn.Position; rbMoved=false
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if rbDragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            rbMoved=true
            local d=i.Position-rbDragStart
            restoreBtn.Position=UDim2.new(rbStartPos.X.Scale,rbStartPos.X.Offset+d.X,rbStartPos.Y.Scale,rbStartPos.Y.Offset+d.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            if not rbMoved and rbDragging then
                restoreBtn.Visible=false; main.Visible=true
                main.Size=UDim2.new(0,W,0,0)
                tween(main,0.3,{Size=UDim2.new(0,W,0,H)},Enum.EasingStyle.Quint)
            end
            rbDragging=false
        end
    end)

    minBtn.MouseButton1Click:Connect(function()
        tween(main,0.25,{Size=UDim2.new(0,W,0,0)},Enum.EasingStyle.Quint)
        task.delay(0.25,function() main.Visible=false; restoreBtn.Visible=true end)
    end)

    -- Separator
    local sep = frame({
        Size=UDim2.new(1,-32,0,1), Position=UDim2.new(0,16,0,headerH),
        BackgroundColor3=Theme.ACCENT1, ZIndex=5,
    }, bgo)
    gradient(Theme.ACCENT1, Theme.ACCENT2, 0, sep)

    -- Drag window (touch + mouse)
    makeDragConn(header, main)

    -- ── SIDEBAR ────────────────────────────────────
    local sidebar = frame({
        Size=UDim2.new(0,sideW,1,-(headerH+1)),
        Position=UDim2.new(0,0,0,headerH+1),
        BackgroundColor3=Theme.SIDEBAR, ZIndex=3,
    }, bgo)

    local sideScroll = Instance.new("ScrollingFrame")
    sideScroll.Size                  = UDim2.new(1,0,1,-8)
    sideScroll.Position              = UDim2.new(0,0,0,4)
    sideScroll.BackgroundTransparency = 1
    sideScroll.ScrollBarThickness    = 0
    sideScroll.CanvasSize            = UDim2.new(0,0,0,0)
    sideScroll.AutomaticCanvasSize   = Enum.AutomaticSize.Y
    sideScroll.ScrollingDirection    = Enum.ScrollingDirection.Y
    -- Mobile: aktifkan touch scroll
    sideScroll.ScrollingEnabled      = true
    sideScroll.Parent                = sidebar
    padding(4, isMobile and 3 or 6, isMobile and 3 or 6, 4, sideScroll)
    listLayout(Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Center, Enum.VerticalAlignment.Top, 3, sideScroll)

    frame({
        Size=UDim2.new(0,1,1,0), Position=UDim2.new(1,0,0,0),
        BackgroundColor3=Theme.STROKE2, ZIndex=4,
    }, sidebar)

    -- ── CONTENT AREA ───────────────────────────────
    local contentArea = frame({
        Size=UDim2.new(1,-(sideW+1),1,-(headerH+1)),
        Position=UDim2.new(0,sideW+1,0,headerH+1),
        BackgroundTransparency=1, ZIndex=3,
    }, bgo)

    -- ================================================
    -- TAB
    -- ================================================
    function Window:AddTab(tabConfig)
        local tabName = tabConfig.Title or "Tab"
        local Tab = {}
        Tab._elements = {}

        -- Tab button (sidebar)
        -- Mobile: lebih tinggi supaya mudah disentuh
        local tabBtnH = isMobile and 40 or 34
        local tabBtn = Instance.new("TextButton")
        tabBtn.Size            = UDim2.new(1, 0, 0, tabBtnH)
        tabBtn.BackgroundColor3 = Theme.BG2
        tabBtn.BackgroundTransparency = 1
        tabBtn.BorderSizePixel = 0
        tabBtn.Text            = ""
        tabBtn.AutoButtonColor = false
        tabBtn.ZIndex          = 5
        tabBtn.Parent          = sideScroll
        corner(8, tabBtn)

        local iconName = tabConfig.Icon or "chevron-right"
        local iconDot  = mkIcon(iconName, isMobile and 12 or 14, Theme.TEXT3, tabBtn, 7)
        iconDot.AnchorPoint = Vector2.new(0, 0.5)
        iconDot.Position    = UDim2.new(0, isMobile and 7 or 10, 0.5, 0)

        local tabNameLbl = label(tabName, isMobile and 11 or 13, Enum.Font.GothamSemibold, Theme.TEXT3, Enum.TextXAlignment.Left, tabBtn)
        -- Mobile: kalau sidebar sempit, sembunyikan teks (hanya icon)
        if isMobile and sideW < 110 then
            tabNameLbl.Text = ""
        else
            tabNameLbl.Size     = UDim2.new(1, -28, 1, 0)
            tabNameLbl.Position = UDim2.new(0, 26, 0, 0)
        end
        tabNameLbl.ZIndex = 7

        local activeBar = frame({
            Size=UDim2.new(0,2,0,18), Position=UDim2.new(0,0,0.5,-9),
            BackgroundColor3=Theme.ACCENT2, BackgroundTransparency=1, ZIndex=6,
        }, tabBtn)
        corner(99, activeBar)

        -- Tab content scroll — mobile lebih nyaman
        local tabContent = Instance.new("ScrollingFrame")
        tabContent.Size                  = UDim2.new(1, 0, 1, 0)
        tabContent.BackgroundTransparency = 1
        tabContent.ScrollBarThickness    = isMobile and 0 or 2
        tabContent.ScrollBarImageColor3  = Theme.STROKE2
        tabContent.CanvasSize            = UDim2.new(0,0,0,0)
        tabContent.AutomaticCanvasSize   = Enum.AutomaticSize.Y
        tabContent.ScrollingDirection    = Enum.ScrollingDirection.Y
        tabContent.ScrollingEnabled      = true
        tabContent.Visible               = false
        tabContent.Parent                = contentArea
        padding(isMobile and 8 or 10, isMobile and 8 or 12, isMobile and 8 or 12, isMobile and 8 or 10, tabContent)
        listLayout(Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Left, Enum.VerticalAlignment.Top, isMobile and 5 or 6, tabContent)

        Tab._btn       = tabBtn
        Tab._content   = tabContent
        Tab._activeBar = activeBar
        Tab._iconDot   = iconDot
        Tab._nameLbl   = tabNameLbl

        local function setIconColor(iconContainer, col)
            if not iconContainer or not iconContainer.Parent then return end
            local inner = iconContainer:FindFirstChildWhichIsA("ImageLabel")
                or iconContainer:FindFirstChildWhichIsA("TextLabel")
            if inner then
                if inner:IsA("ImageLabel") then tween(inner,0.15,{ImageColor3=col})
                else tween(inner,0.15,{TextColor3=col}) end
            end
        end

        local function selectTab()
            for _, t in ipairs(Window._tabs) do
                tween(t._btn,0.15,{BackgroundTransparency=1})
                tween(t._activeBar,0.15,{BackgroundTransparency=1})
                t._nameLbl.TextColor3 = Theme.TEXT3
                setIconColor(t._iconDot, Theme.TEXT3)
                t._content.Visible = false
            end
            tween(tabBtn,0.15,{BackgroundTransparency=0.85})
            tween(activeBar,0.15,{BackgroundTransparency=0})
            tabNameLbl.TextColor3 = Theme.TEXT
            setIconColor(iconDot, Theme.ACCENT2)
            tabContent.Visible = true
            Window._selected   = Tab
        end

        tabBtn.MouseButton1Click:Connect(selectTab)
        -- Mobile: tap juga trigger select
        tabBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then selectTab() end
        end)
        tabBtn.MouseEnter:Connect(function()
            if Window._selected ~= Tab then tween(tabBtn,0.1,{BackgroundTransparency=0.93}) end
        end)
        tabBtn.MouseLeave:Connect(function()
            if Window._selected ~= Tab then tween(tabBtn,0.1,{BackgroundTransparency=1}) end
        end)

