local function makeDragConn(dragFrame, moveFrame)
    local dragging   = false
    local dragInput  = nil
    local dragStart  = nil
    local startPos   = nil
    local function update(input)
        if not dragging then return end
        local delta = input.Position - dragStart
        TweenService:Create(moveFrame, TweenInfo.new(0.02, Enum.EasingStyle.Linear), {
            Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        }):Play()
    end
    dragFrame.InputBegan:Connect(function(i)
        if (i.UserInputType == Enum.UserInputType.MouseButton1
        or  i.UserInputType == Enum.UserInputType.Touch)
        and not dragging then
            dragging   = true
            dragInput  = i
            dragStart  = i.Position
            startPos   = moveFrame.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    dragging  = false
                    dragInput = nil
                end
            end)
        end
    end)
    dragFrame.InputChanged:Connect(function(i)
        if dragging and dragInput == i then
            if i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch then
                update(i)
            end
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and dragInput ~= nil then
            if i.UserInputType == Enum.UserInputType.MouseMovement
            or i.UserInputType == Enum.UserInputType.Touch then
                update(i)
            end
        end
    end)
end
