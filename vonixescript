local hideLineConn = nil; local hideLineWorkspaceConn = nil

local function applyHideLine(obj)
    if not isHideLine then return end
    pcall(function()
        if obj:IsA("Beam") then obj.Enabled=false
        elseif obj:IsA("BasePart") or obj:IsA("MeshPart") then
            local nl=obj.Name:lower()
            if nl:match("line") or nl:match("bobber") or nl:match("hook") or nl:match("lure") or nl:match("string") or nl:match("wire") then
                obj.Transparency=1; obj.CastShadow=false
            end
        elseif obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Sparkles") then obj.Enabled=false end
    end)
end

local function scanAndHideLine()
    local char=Player.Character; if not char then return end
    local tool=char:FindFirstChildOfClass("Tool")
    if tool then for _,v in pairs(tool:GetDescendants()) do applyHideLine(v) end end
    for _,v in pairs(workspace:GetDescendants()) do
        local nl=v.Name:lower()
        if nl:match("fishingline") or nl:match("fishing_line") or nl:match("rodline") or nl:match("castline") or (nl:match("line") and v:IsA("Beam")) then applyHideLine(v) end
        if v:IsA("Beam") or v:IsA("Trail") then applyHideLine(v) end
    end
end

local function setHideLine(state)
    isHideLine=state
    if hideLineConn then hideLineConn:Disconnect(); hideLineConn=nil end
    if hideLineWorkspaceConn then hideLineWorkspaceConn:Disconnect(); hideLineWorkspaceConn=nil end
    if state then
        scanAndHideLine()
        hideLineWorkspaceConn=workspace.DescendantAdded:Connect(function(obj) if isHideLine then pcall(function() applyHideLine(obj) end) end end)
        local _lws=0
        hideLineConn=RunService.Heartbeat:Connect(function()
            if not isHideLine then return end
            local c=Player.Character; if not c then return end
            local tool=c:FindFirstChildOfClass("Tool")
            if tool then for _,v in pairs(tool:GetDescendants()) do pcall(function() applyHideLine(v) end) end end
            local now=tick(); if now-_lws>=1 then _lws=now
                for _,v in pairs(workspace:GetDescendants()) do if v:IsA("Beam") or v:IsA("Trail") then pcall(function() applyHideLine(v) end) end end
            end
        end)
    else
        pcall(function()
            local c=Player.Character; if not c then return end
            local tool=c:FindFirstChildOfClass("Tool"); if not tool then return end
            for _,v in pairs(tool:GetDescendants()) do
                if v:IsA("Beam") then v.Enabled=true end
                if v:IsA("ParticleEmitter") or v:IsA("Trail") then v.Enabled=true end
                if v:IsA("BasePart") or v:IsA("MeshPart") then
                    local nl=v.Name:lower()
                    if nl:match("line") or nl:match("bobber") or nl:match("hook") or nl:match("lure") or nl:match("string") or nl:match("wire") then v.Transparency=0 end
                end
            end
        end)
    end
end

