            for _, opt in ipairs(options) do makeOptBtn(opt) end

            local menuH = #options * optH
            local clickArea = Instance.new("TextButton")
            clickArea.Size=UDim2.new(1,0,1,0); clickArea.BackgroundTransparency=1
            clickArea.Text=""; clickArea.ZIndex=12; clickArea.Parent=row
