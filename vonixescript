local function detectStoneType(req)
    if not req then return nil end
    if req.evoType then
        local et=req.evoType:upper()
        if et=="TIRAN" or et=="CHORMA" or et=="KRYO" then return et end
    end
    local combined=""
    for _,v in pairs(req) do if type(v)=="string" then combined=combined..v:upper() end end
    if not combined:find("TIRAN") and not combined:find("CHORMA") and not combined:find("KRYO") then
        pcall(function()
            local mui=Player.PlayerGui:FindFirstChild("MissionSystemUI"); if not mui then return end
            for _,v in pairs(mui:GetDescendants()) do
                if v:IsA("TextLabel") then
                    local txt=v.Text:upper()
                    if txt:find("TIRAN") or txt:find("CHORMA") or txt:find("KRYO") then combined=combined..txt end
                end
            end
        end)
    end
    if combined:find("TIRAN") then return "TIRAN" end
    if combined:find("CHORMA") then return "CHORMA" end
    if combined:find("KRYO") then return "KRYO" end
    return nil
end

local function reqNeedsStone(req)
    if not req then return false end
    -- Hanya butuh stone kalau ada evoType field yang diset server
    if req.evoType and req.evoType~="" then return true end
    -- Cek dari combined fields: butuh kata "EVO" bukan "SECRET" (SECRET tier biasa ga butuh stone)
    local combined=""
    for _,v in pairs(req) do if type(v)=="string" then combined=combined..v:upper() end end
    return combined:find("EVO")~=nil
end

