    -- ================================================
    -- MONITOR TAB
    -- ================================================
    function Window:AddMonitor(mConfig)
        local tab = self:AddTab({ Title = mConfig.Title or "Monitor", Icon = mConfig.Icon or "activity" })

        local statusBanner = frame({Size=UDim2.new(1,0,0,isMobile and 48 or 52), BackgroundColor3=Theme.BG3}, tab._content)
        corner(10,statusBanner); stroke(Theme.STROKE2,1,statusBanner)

        local statusBar = frame({Size=UDim2.new(0,3,0,32), Position=UDim2.new(0,10,0.5,-16), BackgroundColor3=Theme.GREEN}, statusBanner)
        corner(99,statusBar)

        local pulseConn
        local function startPulse(col)
            if pulseConn then pcall(function() pulseConn:Disconnect() end) end
            statusBar.BackgroundColor3=col
            local bright=col:Lerp(Color3.new(1,1,1),0.3); local t=0
            pulseConn=RunService.Heartbeat:Connect(function(dt)
                t=t+dt*2; local a=(math.sin(t)+1)/2
                statusBar.BackgroundColor3=col:Lerp(bright,a*0.4)
            end)
        end
        startPulse(Theme.TEXT3)

        local statusDot=frame({Size=UDim2.new(0,8,0,8), Position=UDim2.new(0,20,0.5,-4), BackgroundColor3=Theme.TEXT3}, statusBanner)
        corner(99,statusDot)
        local statusLbl=label("IDLE",isMobile and 13 or 14,Enum.Font.GothamBold,Theme.TEXT2,Enum.TextXAlignment.Left,statusBanner)
        statusLbl.Size=UDim2.new(0.6,0,1,0); statusLbl.Position=UDim2.new(0,36,0,0)
        local statusTime=label("--:--",13,Enum.Font.GothamBold,Theme.TEXT3,Enum.TextXAlignment.Right,statusBanner)
        statusTime.Size=UDim2.new(0.4,-14,1,0); statusTime.Position=UDim2.new(0.6,0,0,0)

        local function addCard(parent, cardTitle, value, accent)
            local card=frame({Size=UDim2.new(0.5,-3,0,isMobile and 52 or 58), BackgroundColor3=Theme.BG2}, parent)
            corner(10,card); stroke(Theme.STROKE,1,card)
            local acc=frame({Size=UDim2.new(0,22,0,2), Position=UDim2.new(0,10,0,0), BackgroundColor3=accent or Theme.ACCENT3}, card)
            corner(99,acc); gradient(Theme.ACCENT1,accent or Theme.ACCENT2,0,acc)
            local tl=label(cardTitle,10,Enum.Font.Gotham,Theme.TEXT3,Enum.TextXAlignment.Left,card)
            tl.Size=UDim2.new(1,-12,0,16); tl.Position=UDim2.new(0,10,0,10)
            local vl=label(value,isMobile and 18 or 20,Enum.Font.GothamBlack,Theme.TEXT,Enum.TextXAlignment.Left,card)
            vl.Size=UDim2.new(1,-12,0,24); vl.Position=UDim2.new(0,10,0,isMobile and 26 or 30)
            return card,vl
        end

        local function makeGrid(cardDefs)
            local grid=frame({Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, BackgroundTransparency=1}, tab._content)
            local layout=Instance.new("UIGridLayout")
            layout.CellSize=UDim2.new(0.5,-3,0,isMobile and 52 or 58)
            layout.CellPadding=UDim2.new(0,6,0,6)
            layout.FillDirection=Enum.FillDirection.Horizontal
            layout.HorizontalAlignment=Enum.HorizontalAlignment.Left
            layout.SortOrder=Enum.SortOrder.LayoutOrder; layout.Parent=grid
            layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                grid.Size=UDim2.new(1,0,0,layout.AbsoluteContentSize.Y)
            end)
            local valueLabels={}
            for _,def in ipairs(cardDefs) do
                local _,vl=addCard(grid,def[1],def[2],def[3]); table.insert(valueLabels,vl)
            end
            return valueLabels
        end

        local Monitor={}; Monitor._cards={}; Monitor._bars={}; Monitor._conn=nil

        tab:AddSection({Title="Statistics"})
        local statDefs=mConfig.Stats or {
            {"Total Cast","0"},{"Total Ikan","0"},{"Cast/Menit","0/m"},
            {"Ikan/Menit","0/m"},{"Total Sell","0x"},{"Respawn","0x"},
        }
        Monitor._statLabels=makeGrid(statDefs)

        function Monitor:Update(data)
            if data.status then
                local colors={FISHING=Theme.GREEN,IDLE=Theme.TEXT3,RESPAWNING=Theme.YELLOW,["EQUIP ROD"]=Color3.fromRGB(100,180,255),MISSION=Theme.ACCENT2}
                local col=colors[data.status] or Theme.TEXT3
                statusLbl.Text=data.status; statusLbl.TextColor3=col; statusDot.BackgroundColor3=col; startPulse(col)
            end
            if data.time then statusTime.Text=data.time end
            if data.stats then
                for i,val in ipairs(data.stats) do
                    if Monitor._statLabels[i] then
                        Monitor._statLabels[i].Text=tostring(val)
                        tween(Monitor._statLabels[i],0.1,{TextColor3=Theme.ACCENT2})
                        task.delay(0.15,function() tween(Monitor._statLabels[i],0.2,{TextColor3=Theme.TEXT}) end)
                    end
                end
            end
        end
        function Monitor:StartAutoUpdate(interval, callback)
            if Monitor._conn then Monitor._conn:Disconnect() end
            local t=0
            Monitor._conn=RunService.Heartbeat:Connect(function(dt)
                t=t+dt; if t>=(interval or 0.5) then t=0; local data=callback(); if data then Monitor:Update(data) end end
            end)
        end
        function Monitor:Stop()
            if Monitor._conn then Monitor._conn:Disconnect(); Monitor._conn=nil end
            if pulseConn then pulseConn:Disconnect(); pulseConn=nil end
        end
        return Monitor
    end

    -- Window-level aliases (WindUI compat)
    Window.Section = function(self, cfg)
        local fs={}
        fs.Tab = function(_, tc) return Window:AddTab(tc) end
        return fs
    end

    return Window
end

