                        local ok = pcall(function()
                            if not isFishing then return end

                            -- Step 1: Throw
                            rThrow:FireServer(1, uuid)
                            pcall(function() rBobber:InvokeServer() end)
                            rMini:FireServer(uuid)

                            -- Step 2: Wait (custom delay dari user)
