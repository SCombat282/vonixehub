        function Tab:AddSlider(sConfig)
            local targetParent = self._container or tabContent
            local min   = sConfig.Min or 0
            local max   = sConfig.Max or 100
            local value = math.clamp(sConfig.Value or sConfig.Default or min, min, max)
            local step  = sConfig.Step or 1
            local row = frame({
                Size             = UDim2.new(1, 0, 0, 56),
                BackgroundColor3 = Theme.BG2,
            }, targetParent)
            corner(8, row)
            stroke(Theme.STROKE, 1, row)
            
            local nameLbl = label(sConfig.Title or "Slider", 13, Enum.Font.GothamSemibold, Theme.TEXT2, Enum.TextXAlignment.Left, row)
            nameLbl.Size     = UDim2.new(1, -60, 0, 20)
            nameLbl.Position = UDim2.new(0, 14, 0, 10)
            nameLbl.ZIndex   = 2
            
            local valLbl = label(tostring(value), 12, Enum.Font.GothamBold, Theme.ACCENT2, Enum.TextXAlignment.Right, row)
            valLbl.Size     = UDim2.new(0, 50, 0, 20)
            valLbl.Position = UDim2.new(1, -62, 0, 10)
            valLbl.ZIndex   = 2
            
            local trackBg = frame({
                Size             = UDim2.new(1, -28, 0, 10),
                Position         = UDim2.new(0, 14, 0, 36),
                BackgroundColor3 = Theme.BG4,
                ZIndex           = 2,
            }, row)
            corner(99, trackBg)
            stroke(Theme.STROKE, 1, trackBg)
            
            local fill = frame({
                Size             = UDim2.new((value - min) / (max - min), 0, 1, 0),
                BackgroundColor3 = Theme.ACCENT1,
                ZIndex           = 3,
            }, trackBg)
            corner(99, fill)
            gradient(Theme.ACCENT1, Theme.ACCENT2, 0, fill)
            
            local SlObj = {}
            local function setValue(v, fireCallback)
                v = math.clamp(math.floor(v / step + 0.5) * step, min, max)
                value = v
                SlObj.Value = v
                local ratio = (v - min) / (max - min)
                tween(fill, 0.15, {Size = UDim2.new(ratio, 0, 1, 0)}, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
                valLbl.Text = tostring(v)
                if fireCallback and sConfig.Callback then
                    task.spawn(sConfig.Callback, v)
                end
            end
            
            if sConfig.Maintenance then
                applyOverlayLock(Window, row, "Maintenance")
            elseif sConfig.Locked then
                applyOverlayLock(Window, row, "Premium")
            else
                local draggingSlider = false
                row.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then
                        draggingSlider = true
                        local abs = trackBg.AbsolutePosition
                        local siz = trackBg.AbsoluteSize
                        local ratio = math.clamp((i.Position.X - abs.X) / siz.X, 0, 1)
                        setValue(min + ratio * (max - min), true)
                    end
                end)
                UserInputService.InputChanged:Connect(function(i)
                    if draggingSlider and (i.UserInputType == Enum.UserInputType.MouseMovement
                    or i.UserInputType == Enum.UserInputType.Touch) then
                        local abs = trackBg.AbsolutePosition
                        local siz = trackBg.AbsoluteSize
                        local ratio = math.clamp((i.Position.X - abs.X) / siz.X, 0, 1)
                        setValue(min + ratio * (max - min), true)
                    end
                end)
                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1
                    or i.UserInputType == Enum.UserInputType.Touch then
                        draggingSlider = false
                    end
                end)
                
                row.MouseEnter:Connect(function() tween(row, 0.1, {BackgroundColor3 = Theme.BG3}) end)
                row.MouseLeave:Connect(function() tween(row, 0.1, {BackgroundColor3 = Theme.BG2}) end)
            end
            setValue(value, false)
            SlObj.Value = value
            function SlObj:SetValue(v) setValue(v, true) end
            function SlObj:SetValueSilent(v) setValue(v, false) end
            function SlObj:SetTitle(t) nameLbl.Text = t end
            
            SlObj.Type = "Slider"
            local flag = sConfig.Flag or sConfig.Title
            if flag then Window.Flags[flag] = SlObj end
            
            return SlObj
        end
        function Tab:AddDropdown(dConfig)
            local targetParent = self._container or tabContent
            local isMulti  = dConfig.Multi or false
            local options  = dConfig.Options or dConfig.Values or {}
            local selected = dConfig.Value or dConfig.Default
            if isMulti then
                if type(selected) ~= "table" then
                    selected = (selected and selected ~= "") and {selected} or {}
                end
            else
                if type(selected) == "table" then selected = selected[1] or "" end
                if not selected or selected == "" then selected = options[1] or "" end
            end
            local opened = false
            local DdObj  = {} 
            local wrapper = frame({
