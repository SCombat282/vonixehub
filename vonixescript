local function parsePrice(val)
    local p = val:match("([%d%.]+)%s*CF")
    return p and tonumber(p:gsub("%.", "")) or 0
end

local _cfCache = 0
local function getPlayerCF()
    local ok, val = pcall(function()
        return ReplicatedStorage:WaitForChild("Economy",5):WaitForChild("ToServer",5):WaitForChild("RequestCFSnapshot",5):InvokeServer()
    end)
    if ok and val ~= nil then _cfCache = tonumber(val) or 0 end
    if _cfCache == 0 then
        pcall(function()
            local a = Player.PlayerGui:WaitForChild("CFChip",3):FindFirstChild("Amount",true)
            if a and a:IsA("TextLabel") then _cfCache = tonumber(a.Text:gsub("[%.,%s]","")) or 0 end
        end)
    end
    return _cfCache
end

local function isItemOwned(itemName, category)
    local owned = false
    pcall(function()
        local rs = ReplicatedStorage:WaitForChild("RodShop"):WaitForChild("ToServer")
        if category=="rod" then
            local r = rs:WaitForChild("GetOwnedRods",5):InvokeServer()
            if type(r)=="table" then
                local t = "ROD_"..itemName:upper()
                for _,v in pairs(r) do if type(v)=="table" and v.rodId and v.rodId:upper()==t then owned=true; return end end
            end
        elseif category=="bobber" then
            local ok,r = pcall(function() return ReplicatedStorage:WaitForChild("BobberShop",3):WaitForChild("ToServer",3):WaitForChild("GetOwnedBobbers",3):InvokeServer() end)
            if ok and type(r)=="table" then
                for _,v in pairs(r) do
                    local id = type(v)=="string" and v or (type(v)=="table" and (v.bobberId or v.id or v.Id or v.name or v.Name)) or tostring(v)
                    if id and id:upper()==itemName:upper() then owned=true; return end
                end
            end
        elseif category=="skin" then
            local ok,r = pcall(function() return ReplicatedStorage:WaitForChild("RodSkin",3):WaitForChild("ToServer",3):WaitForChild("GetOwnedSkins",3):InvokeServer() end)
            if ok and type(r)=="table" then
                for _,v in pairs(r) do
                    local id = type(v)=="string" and v or (type(v)=="table" and (v.skinId or v.id or v.Id or v.name or v.Name)) or tostring(v)
                    if id and id:upper()==itemName:upper() then owned=true; return end
                end
            end
        end
    end)
    return owned
end

local function buyItem(p)
    if p.owned then _N({Title="Sudah Dimiliki",Content=p.displayName.." sudah ada!",Type="Warning",Duration=4}); return end
    local cf = getPlayerCF()
    if cf < p.price then _N({Title="CF Tidak Cukup",Content="CF: "..cf.." | Butuh: "..p.price,Type="Error",Duration=5}); return end
    local ok,err = pcall(function() p.remote:FireServer(p.remoteName) end)
    if ok then _N({Title="Berhasil!",Content="Berhasil membeli "..p.displayName,Type="Success",Duration=3})
    else _N({Title="Gagal",Content="Error: "..tostring(err),Type="Error",Duration=5}) end
end

