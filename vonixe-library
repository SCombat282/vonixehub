        -- ── SLIDER ───────────────────────────────
        function Tab:AddSlider(sConfig)
            local min   = sConfig.Min or 0
            local max   = sConfig.Max or 100
            local value = math.clamp(sConfig.Value or min, min, max)
            local step  = sConfig.Step or 1
            local rowH  = isMobile and 54 or 52
            local trkH2 = isMobile and 9 or 6
            local thmS2 = isMobile and 18 or 12

            local row = frame({Size=UDim2.new(1,0,0,rowH), BackgroundColor3=Theme.BG2}, tabContent)
            corner(8,row); stroke(Theme.STROKE,1,row)
            local acc = frame({Size=UDim2.new(0,20,0,2), Position=UDim2.new(0,10,0,0), BackgroundColor3=Theme.ACCENT3, ZIndex=2}, row)
            corner(99,acc); gradient(Theme.ACCENT1,Theme.ACCENT2,0,acc)
            local nameLbl = label(sConfig.Title or "Slider", TS, Enum.Font.GothamSemibold, Theme.TEXT2, Enum.TextXAlignment.Left, row)
            nameLbl.Size=UDim2.new(1,-60,0,20); nameLbl.Position=UDim2.new(0,10,0,10); nameLbl.ZIndex=2
            local valLbl = label(tostring(value), 12, Enum.Font.GothamBold, Theme.ACCENT2, Enum.TextXAlignment.Right, row)
            valLbl.Size=UDim2.new(0,50,0,20); valLbl.Position=UDim2.new(1,-58,0,10); valLbl.ZIndex=2

            local trackBg = frame({
                Size=UDim2.new(1,-20,0,trkH2), Position=UDim2.new(0,10,0,rowH-trkH2-8),
                BackgroundColor3=Theme.BG4, ZIndex=2,
            }, row)
            corner(99,trackBg); stroke(Theme.STROKE,1,trackBg)
            local fill = frame({Size=UDim2.new((value-min)/(max-min),0,1,0), BackgroundColor3=Theme.ACCENT1, ZIndex=3}, trackBg)
            corner(99,fill); gradient(Theme.ACCENT1,Theme.ACCENT2,0,fill)
            local thumb = frame({
                Size=UDim2.new(0,thmS2,0,thmS2),
                Position=UDim2.new((value-min)/(max-min),-thmS2/2,0.5,-thmS2/2),
                BackgroundColor3=Theme.TEXT, ZIndex=4,
            }, trackBg)
            corner(99,thumb)

            local function setValue(v, fireCallback)
                v = math.clamp(math.floor(v/step+0.5)*step, min, max)
                value = v
                local ratio = (v-min)/(max-min)
                tween(fill,0.05,{Size=UDim2.new(ratio,0,1,0)})
                tween(thumb,0.05,{Position=UDim2.new(ratio,-thmS2/2,0.5,-thmS2/2)})
                valLbl.Text = tostring(v)
                if fireCallback and sConfig.Callback then task.spawn(sConfig.Callback,v) end
            end

            -- FIX: drag slider support Mouse + Touch
            local draggingSlider = false
            trackBg.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    draggingSlider = true
                    local ratio = math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                    setValue(min+ratio*(max-min), true)
                end
            end)
            UserInputService.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    draggingSlider = false
                end
            end)
            UserInputService.InputChanged:Connect(function(i)
                if draggingSlider and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                    local ratio = math.clamp((i.Position.X-trackBg.AbsolutePosition.X)/trackBg.AbsoluteSize.X,0,1)
                    setValue(min+ratio*(max-min), true)
                end
            end)

            setValue(value, false)
            local SlObj={}; SlObj.Value=value
            function SlObj:SetValue(v) setValue(v,false); SlObj.Value=value end
            function SlObj:SetTitle(t) nameLbl.Text=t end
            return SlObj
        end

