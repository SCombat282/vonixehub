                       track.Animation.AnimationId:find("111816228301569") then
                        track:Stop(0)
                    end
                end
            end)
            task.wait(0.1)
        end
    end)

    if true then
        -- ── AUTO FISHING (single-thread, anti-stuck) ──
        local w = task.spawn(function()
            local failCount = 0
            while isFishing and activeSessionId == sessionId do
                if rodReady then
                    local uuid = findUUID()
