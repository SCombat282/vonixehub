        function Tab:AddMissionBar()
            local card = frame({Size=UDim2.new(1,0,0,isMobile and 72 or 66), BackgroundColor3=Theme.BG2}, tabContent)
            corner(10, card); stroke(Theme.STROKE, 1, card)

            local acc = frame({Size=UDim2.new(1,0,0,2), BackgroundColor3=Theme.ACCENT3}, card)
