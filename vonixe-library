                tween(track,0.15,{BackgroundColor3=v and Theme.TOGGLE_ON or Theme.TOGGLE_OFF})
                tween(thumb,0.15,{Position=v and UDim2.new(1,-(thumbS+3),0.5,-thumbS/2) or UDim2.new(0,3,0.5,-thumbS/2)})
                if fireCallback and tConfig.Callback then task.spawn(tConfig.Callback, v) end
            end
