                            repeat task.wait() until os.clock() - start >= reelDelay

                            -- Step 3: Reel
                            rReel:FireServer({
                                duration    = 5,
                                result      = "SUCCESS",
                                insideRatio = 1
                            }, uuid)
                            
                            -- Step 4: Anti-Stuck (Legacy)
