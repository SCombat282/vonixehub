                    ob.MouseEnter:Connect(function() tween(ob, 0.08, {BackgroundTransparency = 0.85}) end)
                    ob.MouseLeave:Connect(function() tween(ob, 0.08, {BackgroundTransparency = 1}) end)
                    ob.MouseButton1Click:Connect(function()
                        selected = opt; valLbl.Text = tostring(opt)
                        if dConfig.Callback then task.spawn(dConfig.Callback, opt) end
                        opened = false
                        tween(arrow, 0.15, {Rotation = 0})
                        tween(menu, 0.15, {Size = UDim2.new(1, 0, 0, 0)})
                        task.delay(0.15, function() menu.Visible = false end)
                    end)
                    table.insert(optBtns, ob)
                end
            end
            return DdObj
