                    task.delay(0.15,function() menu.Visible=false end)
                end)
                table.insert(optBtns,ob)
            end
            for _,o in ipairs(options) do mkOpt(o) end
            local menuH = #options * optH

            local ca = Instance.new("TextButton")
            ca.Size=UDim2.new(1,0,1,0); ca.BackgroundTransparency=1
