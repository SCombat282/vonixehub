-- ================================================
-- UTILITY
-- ================================================
local function corner(r, p)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r)
    c.Parent = p
    return c
end

local function stroke(col, thick, p, trans)
    local s = Instance.new("UIStroke")
    s.Color = col
    s.Thickness = thick or 1
    s.Transparency = trans or 0
    s.Parent = p
    return s
end

local function gradient(col1, col2, rot, p)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(col1, col2)
    g.Rotation = rot or 0
    g.Parent = p
    return g
end

local function padding(t, l, r, b, p)
    local pd = Instance.new("UIPadding")
    pd.PaddingTop    = UDim.new(0, t or 0)
    pd.PaddingLeft   = UDim.new(0, l or 0)
    pd.PaddingRight  = UDim.new(0, r or 0)
    pd.PaddingBottom = UDim.new(0, b or 0)
    pd.Parent = p
    return pd
end

local function listLayout(dir, halign, valign, pad, p)
    local ll = Instance.new("UIListLayout")
    ll.FillDirection       = dir or Enum.FillDirection.Vertical
    ll.HorizontalAlignment = halign or Enum.HorizontalAlignment.Left
    ll.VerticalAlignment   = valign or Enum.VerticalAlignment.Top
    ll.Padding             = UDim.new(0, pad or 0)
    ll.SortOrder           = Enum.SortOrder.LayoutOrder
    ll.Parent              = p
    return ll
end

local function tween(obj, t, props, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out),
        props
    ):Play()
end

local function frame(props, p)
    local f = Instance.new("Frame")
    f.BorderSizePixel = 0
    for k, v in pairs(props) do f[k] = v end
    f.Parent = p
    return f
end

local function label(txt, size, font, col, xa, p)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.BorderSizePixel = 0
    l.Text = txt
    l.TextSize = size
    l.Font = font or Enum.Font.Gotham
    l.TextColor3 = col or Theme.TEXT
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextTruncate = Enum.TextTruncate.AtEnd
    l.Parent = p
    return l
end

local function makeDragConn(dragFrame, moveFrame)
    local dragging, dragStart, startPos = false, nil, nil
    dragFrame.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = i.Position
            startPos = moveFrame.Position
        end
    end)
    dragFrame.InputChanged:Connect(function(i)
        if dragging and (i.UserInputType == Enum.UserInputType.MouseMovement
        or i.UserInputType == Enum.UserInputType.Touch) then
            local d = i.Position - dragStart
            moveFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
    dragFrame.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

