local _lastGC=0; local _lastMonitorUpdate=0
RunService.Heartbeat:Connect(function()
    local now=tick()
    updateHideName()
    local gcInt= 30
    if now-_lastGC>=gcInt then
        _lastGC=now; pcall(function() collectgarbage("collect") end); pcall(function() collectgarbage("step",200) end)
        for lbl,conn in pairs(textChangedConns) do if not lbl or not lbl.Parent then pcall(function() conn:Disconnect() end); textChangedConns[lbl]=nil end end
        for lbl in pairs(originalData.overhead) do if not lbl or not lbl.Parent then originalData.overhead[lbl]=nil end end
        for lbl in pairs(originalData.leaderboard) do if not lbl or not lbl.Parent then originalData.leaderboard[lbl]=nil end end
    end
    if now-_lastMonitorUpdate>=1 then
        _lastMonitorUpdate=now
        if isFishing then
            if rodReady and isAntiStuck then idleSeconds=idleSeconds+1 end
            if not isAntiStuck then idleSeconds=0 end
            
            local ss=""
            for st,active in pairs(stoneActive) do if active then ss=" 💎"..st end end
            local statusIcon = isRespawning and "🔄" or (not rodReady and "🎣") or (isAntiStuck and idleSeconds>=10 and "⚠️") or "✅"
            
            local timeText = isAntiStuck and (idleSeconds.."s") or ""
            local statusText = isRespawning and "RESPAWNING..." or (not rodReady and "EQUIP ROD...") or (isAntiStuck and idleSeconds>=10 and "IDLE "..timeText) or ("FISHING "..timeText)
            
            pcall(function() StuckMonitor:SetTitle(statusIcon.." "..statusText..ss) end)
            if isAntiStuck and idleSeconds>=15 and not isRespawning then
                idleSeconds=0
                task.spawn(function() _N({Title="Anti-Stuck",Content="Respawning...",Type="Warning",Duration=3}); forceRespawnAndReturn() end)
            end
        else
            idleSeconds=0
            pcall(function() StuckMonitor:SetTitle("⏸ IDLE — fishing off") end)
        end
    end
end)

