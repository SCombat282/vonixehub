local function doGachaSpin(sessionId)
    local combo=getGachaCombo()
    if not combo then _N({Title="Gacha",Content="Gagal ambil combo!",Type="Error",Duration=4}); return false,"Gagal ambil combo" end

    local f1n=tostring(combo.fish1 or combo.Fish1 or ""):upper():gsub("%s+","_"):gsub("[^%w_]","")
    local f2n=tostring(combo.fish2 or combo.Fish2 or ""):upper():gsub("%s+","_"):gsub("[^%w_]","")
    if f1n=="" or f2n=="" then return false,"Format combo tidak dikenali" end

    _N({Title="Gacha Combo",Content=f1n.." + "..f2n,Type="Info",Duration=5})

    -- Cek ikan dulu di legend list
    local srv0=getGachaToServer()
    local getLegendFishRemote=srv0:FindFirstChild("GetLegendFish")
    local function getLegendFishList()
        if not getLegendFishRemote then return {} end
        local ok,r=pcall(function() return getLegendFishRemote:InvokeServer() end)
        if ok and type(r)=="table" then return r end
        return {}
    end
    local function findInLegendList(list,speciesName)
        local nameUp=speciesName:upper():gsub("%s+","_"):gsub("[^%w_]","")
        for _,fish in pairs(list) do
            if type(fish)=="table" then
                local sp=tostring(fish.Species or fish.species or fish.Name or ""):upper():gsub("%s+","_"):gsub("[^%w_]","")
                if sp~="" and (sp==nameUp or sp:find(nameUp,1,true) or nameUp:find(sp,1,true)) then return fish end
            end
        end
        return nil
    end

    local legendList=getLegendFishList()
    local f1obj=findInLegendList(legendList,f1n)
    local f2obj=findInLegendList(legendList,f2n)

    if not f1obj or not f2obj then
        local missing={}
        if not f1obj then table.insert(missing,f1n) end
        if not f2obj then table.insert(missing,f2n) end
        _N({Title="Gacha",Content="Butuh: "..table.concat(missing,", ")..". Nyalakan Auto Fishing!",Type="Warning",Duration=6})

        -- Tutup dulu UI gachanya dengan sembunyikan (tidak click manual biar game ga ngebug)
        pcall(function()
            local ui = Player.PlayerGui:FindFirstChild("GachaLegendUI")
            if ui then ui.Enabled = false end
        end)
        task.wait(0.3)

        local function getTargetZone()
            local targetFish = not f1obj and f1n or f2n
            return getZoneData(findFishZone(targetFish)) or {cf=CFrame.new(-728,857,-123),freeze=true}
        end
        local zd=getTargetZone()
        tpTo(zd.cf); task.wait(0.1)
        frozenCFrame=zd.cf; setCharFreeze(true)

        local deadline=tick()+300
        while tick()<deadline do
            local missingFish = not f1obj and f1n or f2n
            autoMissionSubtext = "CARI BAHAN: " .. missingFish
            if not isAutoStone or not isAutoMission then setCharFreeze(false); return false,"Stopped" end
            task.wait(5); _snapshotCacheTime=0
            legendList=getLegendFishList()
            f1obj=findInLegendList(legendList,f1n)
            f2obj=findInLegendList(legendList,f2n)
            if f1obj and f2obj then break end
            zd=getTargetZone()
            tpTo(zd.cf); task.wait(0.1); frozenCFrame=zd.cf; setCharFreeze(true)
        end
        
        setCharFreeze(false)
        if not f1obj or not f2obj then return false,"Timeout menunggu ikan" end
        if not isAutoStone then return false,"Stopped" end
    end

    -- Buka NPC
    _N({Title="Gacha",Content="Ikan lengkap! Buka gacha...",Type="Success",Duration=3})
    setCharFreeze(false)
    openGachaNPC()
    task.wait(0.5)

    local ui=Player.PlayerGui:FindFirstChild("GachaLegendUI")
    if not ui then autoMissionSubtext=""; _N({Title="Gacha",Content="UI tidak muncul!",Type="Error",Duration=4}); return false,"UI tidak muncul" end

    local mf=ui:FindFirstChild("MainFrame")
    if not mf then autoMissionSubtext=""; return false,"MainFrame tidak ada" end

    -- Fungsi: klik SelectBox → tunggu FishSelectionPopup → cari ikan → klik child[6]
    local function selectFish(selectBoxName, targetName)
        local cc=mf:FindFirstChild("CurrentCombo"); if not cc then return false end
        local sb=cc:FindFirstChild(selectBoxName); if not sb then return false end

        -- Klik SelectBox untuk munculkan popup
        local sbBtn=sb:FindFirstChildOfClass("ImageButton") or sb:FindFirstChildOfClass("TextButton") or sb
        clickUIBtn(sbBtn)
        task.wait(0.5)

        -- Tunggu FishSelectionPopup muncul
        local popup=ui:FindFirstChild("FishSelectionPopup")
        if not popup then task.wait(0.5); popup=ui:FindFirstChild("FishSelectionPopup") end
        if not popup then return false end

        local fishList=popup:FindFirstChild("FishList")
        if not fishList then return false end
        
        -- Tunggu list ikan meload dari server (maks 3 detik)
        local waitT = 0
        local foundAny = false
        while waitT < 3 do
            for _, c in pairs(fishList:GetChildren()) do
                if c:IsA("Frame") or c:IsA("TextButton") or c:IsA("ImageButton") then
                    foundAny = true; break
                end
            end
            if foundAny then break end
            task.wait(0.2)
            waitT = waitT + 0.2
        end
        if foundAny then task.wait(0.5) end -- Beri jeda 0.5 detik agar label ikan melempar teks

        local targetUp=targetName:upper():gsub("%s+","_"):gsub("[^%w_]","")

        -- Cari frame ikan yang namanya cocok
        for _,fishFrame in pairs(fishList:GetChildren()) do
            if fishFrame:IsA("Frame") or fishFrame:IsA("TextButton") or fishFrame:IsA("ImageButton") then
                local isMatch = false
                pcall(function()
                    for _, d in pairs(fishFrame:GetDescendants()) do
                        if d:IsA("TextLabel") or d:IsA("TextBox") then
                            local tText = d.Text:upper():gsub("%s+","_"):gsub("[^%w_]","")
                            if tText~="" and (tText==targetUp or tText:find(targetUp,1,true) or targetUp:find(tText,1,true)) then
                                isMatch = true
                                break
                            end
                        end
                    end
                end)

                if isMatch then
                    local children = fishFrame:GetChildren()
                    local selectBtn = children[6]
                    
                    if selectBtn then
                        clickUIBtn(selectBtn)
                    else
                        clickUIBtn(fishFrame)
                    end
                    task.wait(0.3)
                    return true
                end
            end
        end
        return false
    end

    -- Pilih ikan 1
    local ok1=selectFish("SelectBox1", f1n)
    if not ok1 then _N({Title="Gacha",Content="Gagal pilih "..f1n,Type="Warning",Duration=4}) end
    task.wait(0.3)

    -- Pilih ikan 2
    local ok2=selectFish("SelectBox2", f2n)
    if not ok2 then _N({Title="Gacha",Content="Gagal pilih "..f2n,Type="Warning",Duration=4}) end
    task.wait(0.3)

    -- Klik PlayButton
    lastSpinReward=nil
    local pb=mf:FindFirstChild("PlayButton")
    if not pb then return false,"PlayButton tidak ada" end
    clickUIBtn(pb)

    -- Tunggu SpinResult (animasi bisa lama, tunggu sampai 15 detik lebih)
    local w=0
    while not lastSpinReward and w<20 do task.wait(0.2); w=w+0.2 end
    
    if not lastSpinReward then
        -- Kalo nggak muncul dapet reward, asumsikan nunggu animasi telat, tambah nunggu
        autoMissionSubtext="WAITING REWARD..."
        task.wait(3)
    end

    task.wait(1); _snapshotCacheTime=0
    return true,"OK"
end

local function farmStoneUntilEnough(stoneType, sessionId)
    local maxSpins=10
    for spin=1,maxSpins do
        if not isAutoStone or not isAutoMission then autoMissionSubtext=""; return false end
        _snapshotCacheTime=0
        if getStoneCount(stoneType)>=1 then autoMissionSubtext=""; return true end
        _N({Title="Auto Stone",Content=stoneType.." stone kosong | Gacha "..spin.."/"..maxSpins,Type="Warning",Duration=3})
        
        autoMissionSubtext = "GACHA STONE: " .. stoneType
        local ok,err=doGachaSpin(sessionId)
        autoMissionSubtext = "GACHA STONE: " .. stoneType
        
        if not isAutoStone or not isAutoMission then autoMissionSubtext=""; return false end
        task.wait(1); _snapshotCacheTime=0
        if getStoneCount(stoneType)>=1 then autoMissionSubtext=""; return true end
        if not ok then autoMissionSubtext="GACHA DELAY..."; task.wait(3) end
    end
    _snapshotCacheTime=0
    autoMissionSubtext=""
    return getStoneCount(stoneType)>=1
end

local stoneBoostConns={}; local stoneActive={}

-- =============================================
-- FIX: handleStoneMission sekarang terima zoneCF
-- supaya bisa TP ke zone misi DULU sebelum gacha
-- =============================================
local function handleStoneMission(stoneType, sessionId, missionZoneCF)
    if not isAutoStone or not isAutoMission then return end
    local cfg=stoneConfig[stoneType]; if not cfg then return end
    stoneActive[stoneType]=false; _snapshotCacheTime=0

    -- STEP 1: Cek stone
    local count=getStoneCount(stoneType)
    _N({Title="Auto Stone",Content="Cek "..stoneType..": "..count.."x",Type="Info",Duration=2})

    -- STEP 2: Kalau ga ada → gacha dulu
    if count<=0 then
        if not isAutoStone or not isAutoMission then return end
        _N({Title="Auto Stone",Content="Ga ada "..stoneType.." stone, gacha...",Type="Warning",Duration=4})
        local ok=farmStoneUntilEnough(stoneType,sessionId)
        if not ok or not isAutoStone or not isAutoMission then
            _N({Title="Auto Stone",Content="Gagal dapat stone!",Type="Error",Duration=5})
            return
        end
    end

    -- STEP 3: TP ke zone misi (cek isAutoMission dulu!)
    if not isAutoMission or not isAutoStone then return end
    if missionZoneCF then
        setCharFreeze(false); task.wait(0.1)
        if not isAutoMission then return end
        tpTo(missionZoneCF); task.wait(0.1)
        frozenCFrame=missionZoneCF; setCharFreeze(true); task.wait(0.3)
    end

    -- STEP 4: Aktifkan stone
    if not isAutoMission or not isAutoStone then setCharFreeze(false); return end
    activateStone(stoneType); stoneActive[stoneType]=true

    -- STEP 5: Listen BoostExpired
    if stoneBoostConns[stoneType] then pcall(function() stoneBoostConns[stoneType]:Disconnect() end); stoneBoostConns[stoneType]=nil end
    pcall(function()
        if not enchantStoneCli then return end
        local ber=enchantStoneCli:FindFirstChild("BoostExpired"); if not ber then return end
        stoneBoostConns[stoneType]=ber.OnClientEvent:Connect(function(expN)
            local eu=(expN or ""):upper()
            if eu:find(stoneType,1,true) or expN==nil then
                stoneActive[stoneType]=false
                if not isAutoStone or not isAutoMission then return end
                _N({Title="Auto Stone",Content=stoneType.." EXPIRED! Ulangi...",Type="Warning",Duration=3})
                task.spawn(function() handleStoneMission(stoneType,activeSessionId,missionZoneCF) end)
            end
        end)
    end)
end

