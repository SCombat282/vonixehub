local hideNameConnections={}
local hideNameDescConn=nil; local hideNameHeadConn=nil; local textChangedConns={}

local function getFakeOverheadText(orig)
    local pN=Player.Name; local dN=Player.DisplayName
    if orig==pN or orig==dN or orig:find(pN,1,true) or orig:find(dN,1,true) then return "Vonixe Hub" end
    local low=orig:lower()
    if low:match("catch") then return "Catch: 1.000.000x" elseif orig:match("%d") then return "Lvl: 999" else return "Vonixe Hub" end
end

local function disconnectLabelHook(lbl)
    if textChangedConns[lbl] then pcall(function() textChangedConns[lbl]:Disconnect() end); textChangedConns[lbl]=nil end
end

local function hookTextChanged(lbl,isOverhead)
    if textChangedConns[lbl] then return end
    textChangedConns[lbl]=lbl:GetPropertyChangedSignal("Text"):Connect(function()
        if not isHideName then return end
        if not lbl or not lbl.Parent then disconnectLabelHook(lbl); return end
        local cur=lbl.Text
        if isOverhead then
            local orig=originalData.overhead[lbl] or cur; local fake=getFakeOverheadText(orig)
            if cur~=fake then lbl.Text=fake end
        else
            local pN=Player.Name; local dN=Player.DisplayName
            if cur==pN or cur==dN then if cur~="Vonixe Hub" then lbl.Text="Vonixe Hub" end
            elseif cur:find(pN,1,true) or cur:find(dN,1,true) then
                local rep=cur:gsub(pN,"Vonixe Hub"):gsub(dN,"Vonixe Hub")
                if cur~=rep then lbl.Text=rep end
            end
        end
    end)
end

local function applyAndHookLabel(v)
    if not isHideName then return end
    if not v or not v.Parent then return end
    if not (v:IsA("TextLabel") or v:IsA("TextBox")) then return end
    local txt=v.Text or ""; local pN=Player.Name; local dN=Player.DisplayName
    local char=Player.Character; local head=char and char:FindFirstChild("Head")
    if head and v:IsDescendantOf(head) then
        if txt~="" then
            if not originalData.overhead[v] then originalData.overhead[v]=txt end
            local fake=getFakeOverheadText(originalData.overhead[v])
            if v.Text~=fake then v.Text=fake end
        end
        hookTextChanged(v,true); return
    end
    if txt~="" then
        local nh=txt==pN or txt==dN or txt:find(pN,1,true) or txt:find(dN,1,true)
        if nh then
            if not originalData.leaderboard[v] then originalData.leaderboard[v]=txt end
            v.Text=(txt==pN or txt==dN) and "Vonixe Hub" or txt:gsub(pN,"Vonixe Hub"):gsub(dN,"Vonixe Hub")
            hookTextChanged(v,false)
        end
    end
end

local function scanAndHideAll()
    for lbl in pairs(originalData.overhead) do if not lbl or not lbl.Parent then originalData.overhead[lbl]=nil; disconnectLabelHook(lbl) end end
    for lbl in pairs(originalData.leaderboard) do if not lbl or not lbl.Parent then originalData.leaderboard[lbl]=nil; disconnectLabelHook(lbl) end end
    local char=Player.Character
    if char then local h=char:FindFirstChild("Head"); if h then for _,v in pairs(h:GetDescendants()) do pcall(function() applyAndHookLabel(v) end) end end end
    for _,sg in pairs(Player.PlayerGui:GetChildren()) do
        if not sg.Name:find("VonixeLib") then
            for _,v in pairs(sg:GetDescendants()) do if v:IsA("TextLabel") or v:IsA("TextBox") then pcall(function() applyAndHookLabel(v) end) end end
        end
    end
end

local function setupHideNameHooks()
    for _,c in pairs(hideNameConnections) do pcall(function() c:Disconnect() end) end; table.clear(hideNameConnections)
    if hideNameDescConn then hideNameDescConn:Disconnect(); hideNameDescConn=nil end
    if hideNameHeadConn then hideNameHeadConn:Disconnect(); hideNameHeadConn=nil end
    for _,conn in pairs(textChangedConns) do pcall(function() conn:Disconnect() end) end
    table.clear(textChangedConns); table.clear(originalData.overhead); table.clear(originalData.leaderboard)
    pcall(function()
        local TCS=game:GetService("TextChatService"); local ex=TCS.OnIncomingMessage
        TCS.OnIncomingMessage=function(msg)
            local props=ex and ex(msg) or Instance.new("TextChatMessageProperties")
            if isHideName then
                local txt=msg.Text or ""; local pN,dN=Player.Name,Player.DisplayName
                if txt:find(pN,1,true) or txt:find(dN,1,true) then props.Text=txt:gsub(pN,"Vonixe Hub"):gsub(dN,"Vonixe Hub") end
            end
            return props
        end
    end)
    hideNameDescConn=Player.PlayerGui.DescendantAdded:Connect(function(v) if isHideName then pcall(function() applyAndHookLabel(v) end) end end)
    local function hookHead(char)
        if hideNameHeadConn then hideNameHeadConn:Disconnect(); hideNameHeadConn=nil end
        local head=char:WaitForChild("Head",5); if not head then return end
        for _,v in pairs(head:GetDescendants()) do pcall(function() applyAndHookLabel(v) end) end
        hideNameHeadConn=head.DescendantAdded:Connect(function(v) if isHideName then pcall(function() applyAndHookLabel(v) end) end end)
    end
    if Player.Character then hookHead(Player.Character) end
    local rc=Player.CharacterAdded:Connect(function(c) if isHideName then task.wait(0.3); hookHead(c) end end)
    table.insert(hideNameConnections,rc); task.spawn(scanAndHideAll)
end

