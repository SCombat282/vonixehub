        local configFolder = Window.ConfigFolder or "VonixeHub"
        local configsFolder = configFolder .. "/Configs"
        
        local function ensureFolders()
            pcall(function()
                if makefolder then
                    if not isfolder(configFolder) then makefolder(configFolder) end
                    if not isfolder(configsFolder) then makefolder(configsFolder) end
                end
            end)
        end
        ensureFolders()
        
        local function getConfigs()
            local list = {}
            pcall(function()
                if listfiles then
                    for _, file in ipairs(listfiles(configsFolder)) do
                        if file:match("%.json$") then
                            local name = file:match("([^/\\]+)%.json$")
                            if name then table.insert(list, name) end
                        end
                    end
                end
            end)
            if #list == 0 then table.insert(list, "---") end
            return list
        end
        
        local configNameInp = ConfigGroup:AddInput({ Title = "Config name", Default = "", Flag = "UI_ConfigName" })
        ConfigGroup:AddButton({
            Title = "Create config",
            Callback = function()
                local name = configNameInp.Value
                if name == "" then return end
                Window:SaveConfig(name)
                Window._configDropdown:Refresh(getConfigs())
                Window._configDropdown:SetValue(name)
                Window:Notify({Title="Success", Content="Created config: " .. name, Type="Success"})
            end
        })
        
        Window._configDropdown = ConfigGroup:AddDropdown({
            Title = "Config list",
            Options = getConfigs(),
            Default = "---",
            Flag = "UI_ConfigList"
        })
        
        ConfigGroup:AddButton({
            Title = "Load config",
            Callback = function()
                local name = Window._configDropdown.Value
                if name and name ~= "---" then
                    Window:LoadConfig(name)
                    Window:Notify({Title="Success", Content="Loaded config: " .. name, Type="Success"})
                end
            end
        })
        ConfigGroup:AddButton({
            Title = "Overwrite config",
            Callback = function()
                local name = Window._configDropdown.Value
                if name and name ~= "---" then
                    Window:SaveConfig(name)
                    Window:Notify({Title="Success", Content="Overwrote config: " .. name, Type="Success"})
                end
            end
        })
        ConfigGroup:AddButton({
            Title = "Delete config",
            Callback = function()
                local name = Window._configDropdown.Value
                if name and name ~= "---" then
                    pcall(function()
                        if delfile then delfile(configsFolder .. "/" .. name .. ".json") end
                    end)
                    Window._configDropdown:Refresh(getConfigs())
                    Window._configDropdown:SetValue("---")
                    Window:Notify({Title="Success", Content="Deleted config: " .. name, Type="Success"})
                end
            end
        })
        ConfigGroup:AddButton({
            Title = "Refresh list",
            Callback = function()
                Window._configDropdown:Refresh(getConfigs())
                Window:Notify({Title="Success", Content="Refreshed config list", Type="Success"})
            end
        })
        
        local autoloadFile = configsFolder .. "/autoload.txt"
        local function getAutoload()
            local al = "none"
            pcall(function()
                if isfile and isfile(autoloadFile) then
                    al = readfile(autoloadFile)
                end
            end)
            return al
        end
        
        local autoloadSection = ConfigGroup:AddSection({ Title = "Current autoload config: " .. getAutoload() })
        
        ConfigGroup:AddButton({
            Title = "Set as autoload",
            Callback = function()
                local name = Window._configDropdown.Value
                if name and name ~= "---" then
                    pcall(function()
                        if writefile then writefile(autoloadFile, name) end
                    end)
                    autoloadSection:SetTitle("Current autoload config: " .. name)
                    Window:Notify({Title="Success", Content="Set autoload to: " .. name, Type="Success"})
                end
            end
        })
        ConfigGroup:AddButton({
            Title = "Reset autoload",
