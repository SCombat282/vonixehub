            stoneLbl.AutomaticSize=Enum.AutomaticSize.X; stoneLbl.Size=UDim2.new(0,0,1,0)
            stoneBadge.Visible=false
            local mainLbl2=label("Mission: OFF",isMobile and 13 or 15,Enum.Font.GothamBlack,Theme.TEXT3,Enum.TextXAlignment.Left,card)
            mainLbl2.Size=UDim2.new(1,-16,0,20); mainLbl2.Position=UDim2.new(0,10,0,24)
            local track=frame({Size=UDim2.new(1,-20,0,5), Position=UDim2.new(0,10,0,cH-14), BackgroundColor3=Color3.fromRGB(24,18,10)},card)
            corner(99,track)
            local fill2=frame({Size=UDim2.new(0,0,1,0), BackgroundColor3=Theme.ACCENT1},track)
            corner(99,fill2); gradient(Theme.ACCENT1,Theme.ACCENT2,0,fill2)
            local progLbl2=label("",10,Enum.Font.GothamBold,Theme.TEXT3,Enum.TextXAlignment.Right,card)
            progLbl2.Size=UDim2.new(1,-20,0,14); progLbl2.Position=UDim2.new(0,10,0,cH-14)

            local pc3
            local function setPulse(col, active)
                if pc3 then pcall(function() pc3:Disconnect() end) end
                dot2.BackgroundColor3=col
                if active then
                    local tt=0; local bright=col:Lerp(Color3.new(1,1,1),0.4)
                    pc3=RunService.Heartbeat:Connect(function(dt) tt=tt+dt*3; dot2.BackgroundColor3=col:Lerp(bright,(math.sin(tt)+1)/2*0.5) end)
                end
            end
            setPulse(Theme.TEXT3,false)

            local tierColors={COMMON=Theme.TEXT2,RARE=Color3.fromRGB(100,180,255),EPIC=Color3.fromRGB(180,100,255),SECRET=Color3.fromRGB(255,200,50),LEGEND=Color3.fromRGB(255,120,30)}
            local MB={}
            function MB:SetStatus(data)
                if not data then
                    mainLbl2.Text="Mission: OFF"; mainLbl2.TextColor3=Theme.TEXT3
                    indexLbl.Text=""; progLbl2.Text=""; stoneBadge.Visible=false
                    tween(fill2,0.3,{Size=UDim2.new(0,0,1,0)}); tween(acc,0.3,{BackgroundColor3=Theme.ACCENT3})
                    setPulse(Theme.TEXT3,false); return
                end
                local col=tierColors[(data.tier or ""):upper()] or Theme.TEXT2
                mainLbl2.Text=(data.tier or "?"):upper().." @ "..(data.zone or "?")
                mainLbl2.TextColor3=col; indexLbl.Text="["..(data.index or "?").."]"; indexLbl.TextColor3=col
                local ratio=(data.total and data.total>0) and math.clamp((data.current or 0)/data.total,0,1) or 0
                tween(fill2,0.4,{Size=UDim2.new(ratio,0,1,0),BackgroundColor3=col})
                tween(acc,0.3,{BackgroundColor3=col})
                progLbl2.Text=(data.current or 0).." / "..(data.total or 0)
                if data.stone and data.stone~="" then stoneLbl.Text="▶ "..data.stone; stoneBadge.Visible=true
                else stoneBadge.Visible=false end
                setPulse(data.active and col or Theme.TEXT3,data.active==true)
            end
            function MB:SetOff() MB:SetStatus(nil) end
            return MB
        end

